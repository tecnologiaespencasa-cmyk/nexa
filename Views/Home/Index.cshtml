<section class="home-hero">
    <img class="home-hero-banner"
         src="~/images/oficina-banner.jpeg"
         asp-append-version="true"
         alt="Equipo de Especialistas en Casa en la oficina" />
    <div class="home-hero-backdrop"></div>

    <div class="home-hero-content">
        <div class="home-shell home-hero-grid">
            <div class="home-hero-copy">
                <span class="home-kicker">Sistema Nexa</span>
                <h1 class="home-hero-title">Bienvenido, @fullName</h1>
                <p class="home-hero-subtitle">Especialistas en casa</p>
                <p class="home-hero-description">
                    Tu punto de entrada para iniciar la jornada con contexto claro, accesos directos y la
                    informacion clave siempre visible.
                </p>
            </div>

            <div class="home-hero-side">
                <img class="home-brand-logo"
                     src="~/images/especialistas-en-casa-logo.png"
                     asp-append-version="true"
                     alt="Especialistas en Casa" />

                <div class="home-clock-panel" aria-live="polite">
                    <span class="home-clock-label">Fecha y hora actual</span>
                    <strong id="home-current-time">@serverNow.ToString("hh:mm:ss tt", culture)</strong>
                    <span id="home-current-date">@culture.TextInfo.ToTitleCase(serverNow.ToString("dddd, dd 'de' MMMM 'de' yyyy", culture))</span>
                </div>
            </div>
        </div>
    </div>

    <div class="home-hero-ribbon">
        <div class="home-shell home-hero-ribbon-grid">
            <div class="home-ribbon-item">
                <span>Usuario activo</span>
                <strong>@fullName</strong>
            </div>
            <div class="home-ribbon-item">
                <span>Plataforma</span>
                <strong>Nexa</strong>
            </div>
            <div class="home-ribbon-item">
                <span>Operacion</span>
                <strong>Especialistas en Casa</strong>
            </div>
        </div>
    </div>
</section>

