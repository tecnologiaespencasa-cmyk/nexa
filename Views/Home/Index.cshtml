@using System.Globalization
@using System.Linq
@using System.Security.Claims
@using IntranetPrueba.Models.Security
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@{
    ViewData["Title"] = "Inicio";

    var fullName = User.FindFirstValue("full_name") ?? User.Identity?.Name ?? "Usuario";
    var firstName = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? fullName;
    var serverNow = DateTime.Now;
    var culture = CultureInfo.GetCultureInfo("es-CO");

    var modules = new[]
    {
        new
        {
            Allowed = (await AuthorizationService.AuthorizeAsync(User, SystemPermissions.Censo)).Succeeded,
            Controller = "Censo",
            Title = "Censo",
            Description = "Gestiona ingresos, seguimiento y plan de manejo del paciente.",
            IconPath = "M7 3a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V9.83A2 2 0 0 0 18.41 8L14 3.59A2 2 0 0 0 12.59 3Zm5 1.5L17.5 10H14a2 2 0 0 1-2-2Z"
        },
        new
        {
            Allowed = (await AuthorizationService.AuthorizeAsync(User, SystemPermissions.Reportes)).Succeeded,
            Controller = "Reportes",
            Title = "Reportes",
            Description = "Consulta resultados, consolidados y vistas de seguimiento.",
            IconPath = "M5 5.5A2.5 2.5 0 0 1 7.5 3h9A2.5 2.5 0 0 1 19 5.5v13a2.5 2.5 0 0 1-2.5 2.5h-9A2.5 2.5 0 0 1 5 18.5Zm3 10.5h2v-5H8Zm3 0h2V8h-2Zm3 0h2v-3h-2Z"
        },
        new
        {
            Allowed = (await AuthorizationService.AuthorizeAsync(User, SystemPermissions.Farmacia)).Succeeded,
            Controller = "Farmacia",
            Title = "Farmacia",
            Description = "Recibe kardex y requisiciones enviados desde censo para despacho.",
            IconPath = "M9 3h6v2h3a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3Zm1 6v3H7v2h3v3h2v-3h3v-2h-3V9Z"
        },
        new
        {
            Allowed = (await AuthorizationService.AuthorizeAsync(User, SystemPermissions.AuditRead)).Succeeded,
            Controller = "Audit",
            Title = "Auditoria",
            Description = "Revisa eventos, trazabilidad y actividad reciente del sistema.",
            IconPath = "M12 3 4 6v6c0 5.25 3.44 9.74 8 11 4.56-1.26 8-5.75 8-11V6Zm0 4a3 3 0 1 1-3 3 3 3 0 0 1 3-3Zm0 11a7.3 7.3 0 0 1-4.52-1.62A5.61 5.61 0 0 1 12 14a5.61 5.61 0 0 1 4.52 2.38A7.3 7.3 0 0 1 12 18Z"
