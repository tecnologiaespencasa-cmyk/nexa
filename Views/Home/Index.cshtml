            Allowed = (await AuthorizationService.AuthorizeAsync(User, SystemPermissions.InventarioBiomedico)).Succeeded,
            Controller = "InventarioBiomedico",
            Title = "Inventario biomedico",
            Description = "Controla equipos, disponibilidad y movimiento de activos.",
            IconPath = "M7 4h10a2 2 0 0 1 2 2v3h-2V6H7v12h4v2H7a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Zm8 6 4 4-4 4v-3h-5v-2h5Z"
        },
        new
        {
            Allowed = (await AuthorizationService.AuthorizeAsync(User, SystemPermissions.UserAdministration)).Succeeded,
            Controller = "UserAdministration",
            Title = "Administracion",
            Description = "Administra usuarios, permisos y seguridad operativa.",
            IconPath = "M9 11a4 4 0 1 0-4-4 4 4 0 0 0 4 4Zm7.5.5 1.09-2.18 1.8.7.61 2.36 2 .72v1.8l-2 .72-.61 2.36-1.8.7-1.09-2.18H15l-1.09 2.18-1.8-.7-.61-2.36-2-.72v-1.8l2-.72.61-2.36 1.8-.7L15 11.5Zm-7.5 1.5c3.31 0 6 1.79 6 4v1H3v-1c0-2.21 2.69-4 6-4Zm8 1.25a1.75 1.75 0 1 0 1.75 1.75A1.75 1.75 0 0 0 17 14.25Z"
