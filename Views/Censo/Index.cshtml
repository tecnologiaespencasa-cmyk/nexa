<section class="censo-history-shell">
    <div class="censo-history-shell__header">
        <div class="censo-history-shell__header-copy">
        <span class="censo-history-shell__eyebrow">Historial</span>
        <h2>Tabla completa de censo</h2>
        <p>
            @if (Model.EditingRecordId.HasValue)
            {
                @:Editando la última atención de la cédula @Model.CedulaFiltro (registro #@Model.EditingRecordId).
            }
            else if (string.IsNullOrWhiteSpace(Model.CedulaFiltro))
            {
                @:Se muestran los últimos 100 registros del censo.
            }
            else
            {
                @:Se muestran todos los registros encontrados para la cédula @Model.CedulaFiltro.
            }
        </p>
        @if (Model.TieneFiltroFechaIngreso)
        {
            <p class="censo-history-shell__subnote">
                Filtro activo por fecha de ingreso desde @(Model.FechaIngresoFiltroDesde?.ToString("dd/MM/yyyy") ?? "el inicio disponible") hasta @(Model.FechaIngresoFiltroHasta?.ToString("dd/MM/yyyy") ?? "la fecha mÃ¡xima disponible").
            </p>
        }
        </div>
        <div class="censo-history-shell__meta" aria-label="Resumen y filtros del historial">
            <div class="censo-history-shell__pill censo-history-shell__pill--highlight">
                <span class="censo-history-shell__pill-label">Ingresos hoy</span>
                <strong>@Model.IngresosHoyCount</strong>
                <small>Calculado por la fecha de ingreso del día actual.</small>
            </div>
            <form method="get" asp-action="Index" class="censo-history-filter" aria-label="Filtro por rango de fecha de ingreso">
                @if (!string.IsNullOrWhiteSpace(Model.CedulaFiltro))
                {
                    <input type="hidden" name="cedulaPaciente" value="@Model.CedulaFiltro" />
                }
                <div class="censo-history-filter__grid">
                    <div class="censo-history-filter__field">
                        <label for="fechaIngresoDesde">Fecha de ingreso desde</label>
                        <input type="date" id="fechaIngresoDesde" name="fechaIngresoDesde" value="@Model.FechaIngresoFiltroDesde?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                    <div class="censo-history-filter__field">
                        <label for="fechaIngresoHasta">Fecha de ingreso hasta</label>
                        <input type="date" id="fechaIngresoHasta" name="fechaIngresoHasta" value="@Model.FechaIngresoFiltroHasta?.ToString("yyyy-MM-dd")" class="form-control" />
                    </div>
                </div>
                <div class="censo-history-filter__actions">
                    <button type="submit" class="btn btn-primary censo-history-filter__submit">Filtrar rango</button>
                    <a class="btn btn-outline-secondary censo-history-filter__reset" asp-action="Index" asp-route-cedulaPaciente="@Model.CedulaFiltro">Limpiar rango</a>
                    @if (Model.TieneFiltroFechaIngreso)
                    {
                        <a class="btn censo-history-filter__export" asp-action="ExportarExcelFiltroPersonalizado" asp-route-cedulaPaciente="@Model.CedulaFiltro" asp-route-fechaIngresoDesde="@Model.FechaIngresoFiltroDesde?.ToString("yyyy-MM-dd")" asp-route-fechaIngresoHasta="@Model.FechaIngresoFiltroHasta?.ToString("yyyy-MM-dd")">Exportar a Excel filtro personalizado</a>
                    }
                </div>
            </form>
        </div>
    </div>

    @if (Model.TieneFiltroFechaIngreso)
    {
        <div class="censo-history-shell__hint">
            Mostrando en tabla los primeros 50 registros del rango seleccionado. La exportación personalizada incluye todo el rango filtrado.
        </div>
    }

    @if (!Model.CensoTableRecords.Any())
    {
        <div class="alert alert-warning mb-0">
            @(string.IsNullOrWhiteSpace(Model.CedulaFiltro)
                ? "No hay registros de censo para mostrar."
                : "No se encontraron registros para la cédula consultada.")
        </div>
    }
    else
    {
        <div class="censo-history-table-wrap">
            <table class="table table-sm table-bordered censo-history-table mb-0">
                <thead>
                    <tr>
                        <th scope="col">Abrir</th>
@foreach (var column in censoTableColumns)
{
                        <th scope="col">@column.Name</th>
}
                        <th scope="col">Adjuntos</th>
                    </tr>
                </thead>
                <tbody>
@foreach (var record in Model.CensoTableRecords)
{
    var alertaFarmacia = record.FarmaciaEnviadoAtUtc.HasValue
        && record.FarmaciaEstado == "Nuevo"
        && (DateTime.UtcNow - record.FarmaciaEnviadoAtUtc.Value).TotalMinutes > 15;
                    <tr class="@(alertaFarmacia ? "censo-row--alerta-farmacia" : null)">
                        <td>
                            <a class="censo-history-table__open" asp-action="Index" asp-route-recordId="@record.Id" asp-route-cedulaPaciente="@Model.CedulaFiltro" asp-route-fechaIngresoDesde="@Model.FechaIngresoFiltroDesde?.ToString("yyyy-MM-dd")" asp-route-fechaIngresoHasta="@Model.FechaIngresoFiltroHasta?.ToString("yyyy-MM-dd")" title="Cargar registro @record.Id para editar" aria-label="Cargar registro @record.Id para editar">
                                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                                    <circle cx="11" cy="11" r="6"></circle>
                                    <path d="M16 16l5 5"></path>
                                </svg>
                            </a>
                            @if (!string.IsNullOrWhiteSpace(record.ProrrogaJson))
                            {
                                <span class="badge bg-warning text-dark ms-1" style="font-size:0.65em;">PRÓRROGA</span>
                            }
                        </td>
@foreach (var column in censoTableColumns)
{
    var rawValue = column.GetValue(record);
    var displayValue = string.Empty;
    if (rawValue is DateTime dateTimeValue)
    {
        displayValue = dateTimeValue.ToString("yyyy-MM-dd HH:mm:ss");
    }
    else if (rawValue is TimeSpan timeSpanValue)
    {
        displayValue = timeSpanValue.ToString(@"hh\:mm\:ss");
    }
    else if (rawValue is not null)
    {
        displayValue = rawValue.ToString() ?? string.Empty;
    }
                        <td>@displayValue</td>
}
                        <td>@(Model.RecordIdsConAdjuntos.Contains(record.Id) ? "Sí" : "No")</td>
                    </tr>
}
                </tbody>
            </table>
        </div>
    }
</section>

<div class="modal fade censo-kardex-modal" id="censoKardexModal" tabindex="-1" aria-labelledby="censoKardexModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header censo-document-header">
                <div class="censo-document-header__title">
                    <span class="censo-card-heading__eyebrow">Gesti&oacute;n</span>
                    <h5 class="modal-title" id="censoKardexModalTitle">Gestionar kardex y requisici&oacute;n</h5>
                </div>
                <div class="censo-document-switch censo-document-switch--header" role="tablist" aria-label="Seleccionar documento">
