            const escapeHtml = (value) => {
                return String(value)
                    .replace(/&/g, "&amp;")
                    .replace(/</g, "&lt;")
                    .replace(/>/g, "&gt;")
                    .replace(/"/g, "&quot;")
                    .replace(/'/g, "&#39;");
            };

            const normalizeCedulaFilter = (value) => String(value || "").replace(/\D/g, "").trim();

            const normalizeMedicationKey = (value) => String(value || "")
                .normalize("NFD")
                .replace(/[\u0300-\u036f]/g, "")
                .toUpperCase()
                .replace(/[^A-Z0-9]+/g, " ")
                .trim()
                .replace(/\s+/g, " ");

            const medicamentoCatalogByName = new Map((Array.isArray(medicamentoCatalog) ? medicamentoCatalog : [])
                .map((item) => [item.NormalizedNombre || normalizeMedicationKey(item.Nombre), item])
                .filter(([key]) => key));

            const getFormControlByName = (name) => form ? form.querySelector(`[name='${name}']`) : null;

            const getFormValue = (name) => {
                const control = getFormControlByName(name);
                return control ? String(control.value || "").trim() : "";
            };

            const setKardexFieldValue = (field, value) => {
                const control = document.querySelector(`#censoKardexModal [data-kardex-field='${field}']`);
                if (control) {
                    control.value = value || "";
                }
            };

            const formatDateForKardex = (value) => {
                if (!value) {
                    return "";
                }

                const parts = String(value).split("-");
                if (parts.length !== 3) {
                    return value;
                }

                return `${parts[2]}/${parts[1]}/${parts[0]}`;
            };

            const buildMedicationDoseText = (medication) => {
                const doseParts = [
                    medication.dose,
                    medication.measure
                ].filter((part) => part);

                return [
                    medication.name,
                    doseParts.join(" "),
                    medication.route,
                    medication.frequency,
                    medication.days ? `POR ${medication.days} DIAS` : ""
                ]
                    .filter((part) => part)
                    .join(" ")
                    .toUpperCase();
            };

            const catalogValue = (metadata, field) => metadata && metadata[field] ? String(metadata[field]).trim() : "";

            const formatInfusionTime = (metadata) => {
                const value = catalogValue(metadata, "TiempoInfusionMinutos");
                if (!value || /NO APLICA/i.test(value) || /ORDEN MEDICA/i.test(value)) {
                    return value;
                }

                return /^\d+([.,]\d+)?$/.test(value) ? `${value} MIN` : value;
            };

            const setKardexMedicationRowField = (row, field, value) => {
                const control = document.querySelector(`#censoKardexModal [data-kardex-med-row='${row}'] [data-kardex-med-field='${field}']`);
                if (control) {
