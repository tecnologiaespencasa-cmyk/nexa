                            }
                            if (medicamento4Toggle && medicamento4Toggle.checked) {
                                required.push("NombreMedicamentoNumero4", "DosisMedicamento4", "MedidaMedicamento4", "ViaAdministracionMedicamento4", "FrecuenciaAdministracionMedicamento4", "DiasMedicamento4");
                            }
                            if (medicamento5Toggle && medicamento5Toggle.checked) {
                                required.push("NombreMedicamentoNumero5", "DosisMedicamento5", "MedidaMedicamento5", "ViaAdministracionMedicamento5", "FrecuenciaAdministracionMedicamento5", "DiasMedicamento5");
                            }
                            if (medicamento6Toggle && medicamento6Toggle.checked) {
                                required.push("NombreMedicamentoNumero6", "DosisMedicamento6", "MedidaMedicamento6", "ViaAdministracionMedicamento6", "FrecuenciaAdministracionMedicamento6", "DiasMedicamento6");
                            }
                        }


                        if (cateterPiccSelect && String(cateterPiccSelect.value || "").toLowerCase() === "si") {
                            required.push("FechaUltimaCuracionPicc");
                        }

                        if (aislamientoSelect && String(aislamientoSelect.value || "").toLowerCase() === "si") {
                            required.push("TipoAislamiento");
                        }

                        if (hasServiciosComplementarios) {
                            required.push("ServicioComplementario");
                        }

                        return required;
                    }
                }
            ];

            const isRequiredFieldCompleted = (fieldName) => {
                if (!form || !fieldName) {
                    return true;
                }

                const fieldNodes = form.querySelectorAll(`[name="${fieldName}"]`);
                if (!fieldNodes || fieldNodes.length === 0) {
                    return true;
                }

                const firstNode = fieldNodes[0];
                if (firstNode.type === "radio") {
                    return Array.from(fieldNodes).some((field) => field.checked);
                }

                if (firstNode.type === "checkbox") {
                    return firstNode.checked;
                }

                return String(firstNode.value || "").trim().length > 0;
            };

            const getMissingMandatorySectionsOnClient = () => {
                return mandatorySectionsConfig
                    .filter((section) => section.getRequiredFields().some((fieldName) => !isRequiredFieldCompleted(fieldName)))
                    .map((section) => section.name);
            };

            const setDireccionMessage = (type, messageHtml) => {
                if (!direccionMensaje) {
                    return;
                }

                direccionMensaje.className = `alert alert-${type} mt-2`;
                direccionMensaje.innerHTML = messageHtml;
            };

            const applyAddressCandidate = async (candidate) => {
                if (!candidate) {
                    return;
                }

                const selectedMunicipality = candidate.municipality || "";
                const selectedNeighborhood = (candidate.neighborhood || candidate.district || "").trim();
                lastValidationDistrict = candidate.district || "";

                if (direccionInput && candidate.formattedAddress) {
                    direccionInput.value = candidate.formattedAddress;
                }

                if (municipioSelect) {
                    if (selectedMunicipality) {
                        const hasOption = Array.from(municipioSelect.options).some(x => x.value === selectedMunicipality);
                        municipioSelect.value = hasOption ? selectedMunicipality : "";
                    } else {
                        municipioSelect.value = "";
                    }
                }

                await applyMunicipalityDefaults(selectedMunicipality, selectedNeighborhood, lastValidationDistrict);
                await loadBarriosByMunicipio(selectedMunicipality, selectedNeighborhood || "a", selectedNeighborhood, false);

                if (barrioSelect) {
                    setBarrioOptions(barriosLoaded, selectedNeighborhood, false);
                }

                if (zonaSelect && candidate.zonaDireccionSegunMunicipio) {
                    zonaSelect.value = candidate.zonaDireccionSegunMunicipio;
                }

                if (clasificacionSelect && candidate.clasificacionZonaSura) {
                    clasificacionSelect.value = candidate.clasificacionZonaSura;
                }

                direccionValidada = true;
                latestAddressCandidates = [];
                setDireccionMessage("success", "Direccion seleccionada correctamente desde las coincidencias de Google.");
            };

            const renderAddressCandidates = (candidates) => {
                const safeCandidates = (candidates || []).filter((x) => !!x && !!x.formattedAddress);
                latestAddressCandidates = safeCandidates;

                if (safeCandidates.length === 0) {
                    return false;
                }

                const optionsHtml = safeCandidates
                    .map((candidate, index) => {
                        const municipio = candidate.municipality ? ` (${escapeHtml(candidate.municipality)})` : "";
                        return `<button type="button" class="btn btn-sm btn-outline-secondary d-block text-start w-100 mb-1 js-direccion-candidate" data-index="${index}">${escapeHtml(candidate.formattedAddress)}${municipio}</button>`;
                    })
                    .join("");

                setDireccionMessage(
                    "warning",
                    `Se encontraron varias direcciones coincidentes. Selecciona la correcta:<div class="mt-2">${optionsHtml}</div>`);

                document.querySelectorAll(".js-direccion-candidate").forEach((button) => {
                    button.addEventListener("click", async () => {
                        const index = Number(button.getAttribute("data-index"));
                        if (!Number.isFinite(index) || index < 0 || index >= latestAddressCandidates.length) {
                            return;
                        }

                        await applyAddressCandidate(latestAddressCandidates[index]);
                    });
                });

                return true;
            };

            const setBarrioOptions = (options, selectedValue, preserveCurrentSelection = true) => {
                if (!barrioSelect) {
                    return;
                }

                const currentValue = preserveCurrentSelection ? (barrioSelect.value || "") : "";
                const targetValueSource = selectedValue ?? currentValue;
                const targetValue = String(targetValueSource || "").trim();
                const uniqueOptions = Array.from(new Set((options || [])
                    .map((x) => (x || "").trim())
                    .filter((x) => x)));

                barrioSelect.innerHTML = "";

                const placeholder = document.createElement("option");
                placeholder.value = "";
                placeholder.textContent = "Selecciona barrio...";
                placeholder.disabled = true;
                placeholder.hidden = true;
                barrioSelect.appendChild(placeholder);

                uniqueOptions.forEach((opt) => {
                    const option = document.createElement("option");
                    option.value = opt;
                    option.textContent = opt;
                    barrioSelect.appendChild(option);
                });

                if (targetValue) {
                    const hasTarget = uniqueOptions.some((opt) => opt.toLowerCase() === targetValue.toLowerCase());
                    if (!hasTarget) {
                        const dynamicOption = document.createElement("option");
                        dynamicOption.value = targetValue;
                        dynamicOption.textContent = targetValue;
                        barrioSelect.appendChild(dynamicOption);
                    }

                    barrioSelect.value = targetValue;
                }

                syncSelectPlaceholderState(barrioSelect);
            };

            const clearAddressDerivedFields = () => {
                lastValidationDistrict = "";
                barriosLoaded = [];
                setBarrioOptions([], "", false);

                if (clasificacionSelect) {
                    clasificacionSelect.value = "";
                }
                if (municipioSelect) {
                    municipioSelect.value = "";
                }
                if (zonaSelect) {
                    zonaSelect.value = "";
                }
                if (areaSelect) {
                    areaSelect.value = "";
                }
                if (barrioSelect) {
                    barrioSelect.value = "";
                }
                if (asumirDireccionCheck) {
                    asumirDireccionCheck.checked = false;
                }
            };

            const clearAllAddressData = () => {
                if (direccionInput) {
                    direccionInput.value = "";
                }

                direccionValidada = false;
                latestAddressCandidates = [];
                clearAddressDerivedFields();
                clearDireccionMessage();
                clearServerDireccionMessage();
            };

            initializeCensoSelectPlaceholders();

            if (cedulaFiltroInput) {
                cedulaFiltroInput.value = normalizeCedulaFilter(cedulaFiltroInput.value);
                cedulaFiltroInput.addEventListener("input", () => {
                    cedulaFiltroInput.value = normalizeCedulaFilter(cedulaFiltroInput.value);
                });
                cedulaFiltroInput.addEventListener("keydown", (event) => {
                    if (event.key !== "Enter") {
                        return;
                    }

                    event.preventDefault();
                    if (buscarCedulaBtn) {
                        buscarCedulaBtn.click();
                    }
                });
            }

            if (buscarCedulaBtn) {
                buscarCedulaBtn.addEventListener("click", () => {
                    const cedula = normalizeCedulaFilter(cedulaFiltroInput ? cedulaFiltroInput.value : "");
                    if (cedulaFiltroInput) {
                        cedulaFiltroInput.value = cedula;
                    }

                    redirectToCedulaFilter(cedula);
                });
            }

            if (limpiarCedulaBtn) {
                limpiarCedulaBtn.addEventListener("click", () => {
                    redirectToCedulaFilter("");
                });
            }

            if (barrioSelect) {
                barriosLoaded = Array.from(barrioSelect.options)
                    .map((option) => (option.value || "").trim())
                    .filter((value) => !!value);
            }

            const applyMunicipalityDefaults = async (municipio, barrio, district) => {
                if (!municipio) {
                    return;
                }

                try {
                    const url = new URL(defaultsMunicipioUrl, window.location.origin);
                    url.searchParams.set("municipio", municipio);
                    if (barrio) {
                        url.searchParams.set("barrio", barrio);
                    }
                    if (district) {
                        url.searchParams.set("district", district);
                    }

                    const response = await fetch(url);
                    if (!response.ok) {
                        return;
                    }

                    const data = await response.json();
                    if (clasificacionSelect && data.clasificacionZonaSura) {
                        clasificacionSelect.value = data.clasificacionZonaSura;
                    }
                    if (zonaSelect && data.zonaDireccionSegunMunicipio) {
                        zonaSelect.value = data.zonaDireccionSegunMunicipio;
                    }
                } catch {
                    // Sin bloqueo, solo no aplicar defaults automaticos.
                }
            };

            const loadBarriosByMunicipio = async (municipio, term, selectedBarrio, preserveCurrentSelection = true) => {
                if (!municipio) {
                    barriosLoaded = [];
                    setBarrioOptions([], "", false);
                    return;
                }

                try {
                    const response = await fetch(`${buscarBarriosUrl}?municipio=${encodeURIComponent(municipio)}&term=${encodeURIComponent(term || "a")}`);
                    if (!response.ok) {
                        barriosLoaded = [];
                        setBarrioOptions([], "", false);
                        return;
                    }

                    const data = await response.json();
                    barriosLoaded = (data.neighborhoods || []).filter((x) => !!x);
                    setBarrioOptions(barriosLoaded, selectedBarrio, preserveCurrentSelection);
                } catch {
                    barriosLoaded = [];
                    setBarrioOptions([], "", false);
                }
            };

            const setFormValueByName = (name, value) => {
                const control = getFormControlByName(name);
                if (!control) {
                    return;
                }

                control.value = value ?? "";
                uppercaseControlValue(control);
                if (control.matches("select")) {
                    syncSelectPlaceholderState(control);
                }
            };

            if (usarSugerenciaServerBtn && direccionInput) {
                usarSugerenciaServerBtn.addEventListener("click", (event) => {
                    event.preventDefault();
                    const serverSuggestionElement = document.querySelector("#direccionValidacionServerMensaje strong");
                    if (serverSuggestionElement) {
                        direccionInput.value = serverSuggestionElement.textContent || "";
                        direccionValidada = false;
                        clearServerDireccionMessage();
                    }
                });
            }

            if (direccionInput) {
                direccionInput.addEventListener("input", () => {
                    direccionValidada = false;
                    latestAddressCandidates = [];
                    clearDireccionMessage();
                    clearServerDireccionMessage();
                });
            }

            if (limpiarDireccionBtn) {
                limpiarDireccionBtn.addEventListener("click", () => {
                    clearAllAddressData();
                });
            }

            if (validarDireccionBtn && direccionInput && csrfTokenInput) {
                validarDireccionBtn.addEventListener("click", async () => {
                    const direccion = (direccionInput.value || "").trim();
                    if (!direccion) {
                        setDireccionMessage("warning", "Debes escribir una dirección para validarla.");
                        direccionValidada = false;
                        return;
                    }

                    validarDireccionBtn.disabled = true;
                    clearDireccionMessage();
                    clearServerDireccionMessage();

                    try {
                        const response = await fetch(validarDireccionUrl, {
                            method: "POST",
                            headers: {
                                "Content-Type": "application/json",
                                "RequestVerificationToken": csrfTokenInput.value
                            },
                            body: JSON.stringify({ direccion })
                        });

                        if (!response.ok) {
                            throw new Error("No se pudo validar la dirección.");
                        }

                        const data = await response.json();
                        direccionValidada = data.isValid === true;
                        latestAddressCandidates = [];
                        const shouldClearDerivedData = data.outcome === "invalid" || data.outcome === "unavailable";
                        const hasAddressCandidates = data.requiresSelection === true
                            && Array.isArray(data.candidates)
                            && data.candidates.length > 1;
                        const suggestedBarrio = (data.neighborhood || data.district || "").trim();

                        if (shouldClearDerivedData) {
                            clearAddressDerivedFields();
                        }

                        if (!shouldClearDerivedData && hasAddressCandidates) {
                            clearAddressDerivedFields();
                            direccionValidada = false;
                            renderAddressCandidates(data.candidates);
                            return;
                        }

                        if (!shouldClearDerivedData && municipioSelect && data.municipality) {
                            const hasOption = Array.from(municipioSelect.options).some(x => x.value === data.municipality);
                            if (hasOption) {
                                if (barrioSelect) {
                                    barrioSelect.value = "";
                                }

                                municipioSelect.value = data.municipality;
                                lastValidationDistrict = data.district || "";
                                await applyMunicipalityDefaults(data.municipality, suggestedBarrio, lastValidationDistrict);
                                await loadBarriosByMunicipio(data.municipality, suggestedBarrio || "a", suggestedBarrio, false);
                            }
                        }

                        if (!shouldClearDerivedData && barrioSelect) {
                            setBarrioOptions(barriosLoaded, suggestedBarrio, false);
                        }

                        if (!shouldClearDerivedData && zonaSelect && data.zonaDireccionSegunMunicipio) {
                            zonaSelect.value = data.zonaDireccionSegunMunicipio;
                        }

                        if (data.isValid) {
                            if (data.formattedAddress) {
                                direccionInput.value = data.formattedAddress;
                            }
                            setDireccionMessage("success", data.message || "Direccion validada correctamente.");
                            return;
                        }

                        let messageHtml = data.message || "La dirección no pudo ser validada.";
                        if (data.suggestedAddress) {
                            messageHtml += `<br/>Sugerencia: <strong>${escapeHtml(data.suggestedAddress)}</strong> <button type="button" class="btn btn-sm btn-link p-0 ms-2" id="usarSugerenciaDireccionBtnClient">Usar sugerencia</button>`;
                        }
                        setDireccionMessage("warning", messageHtml);

                        const usarSugerenciaClientBtn = document.getElementById("usarSugerenciaDireccionBtnClient");
                        if (usarSugerenciaClientBtn && data.suggestedAddress) {
                            usarSugerenciaClientBtn.addEventListener("click", (event) => {
                                event.preventDefault();
                                direccionInput.value = data.suggestedAddress;
                                direccionValidada = false;
                            });
                        }
                    } catch {
                        direccionValidada = false;
                        clearAddressDerivedFields();
                        setDireccionMessage("danger", "No fue posible validar la dirección. Intenta nuevamente o marca 'Asumir dirección errada y continuar'.");
                    } finally {
                        validarDireccionBtn.disabled = false;
                    }
                });
            }

            if (form && asumirDireccionCheck) {
                form.addEventListener("submit", (event) => {
                    uppercaseAllCensoTextFields();
                    [telefono1Input, telefono2Input, telefono3Input, numeroTelefonoLlamadaBienvenidaInput].forEach((input) => sanitizePhoneInput(input));
                    [diasMedicamentoPrincipalInput, diasMedicamento2Input, diasMedicamento3Input, diasMedicamento4Input, diasMedicamento5Input, diasMedicamento6Input].forEach((input) => sanitizeDaysInput(input));
                    syncMedicationVisibility();
                    syncAllMedicationDailyDoses();
                    syncAplicacionesTotales();
                    syncPhoneVisibility();
                    syncFechaProximoCambioSonda();
                    syncCateterismoVisibility();
                    syncCateterPiccVisibility();
                    syncGestionAltaVisibility();

                    if (codigoCie10Input) {
                        codigoCie10Input.value = normalizeCie10InputValue(codigoCie10Input.value || "");
                    }

                    const missingMandatorySections = getMissingMandatorySectionsOnClient();
                    if (missingMandatorySections.length > 0) {
                        event.preventDefault();

                        const firstMissingSection = mandatorySectionsConfig.find((section) => section.name === missingMandatorySections[0]);
                        if (firstMissingSection) {
                            openSectionTab(firstMissingSection.tabLinkId);
                        }

                        showFeedbackModal(
                            "Faltan secciones obligatorias",
                            `<p class="mb-2">Para guardar debes completar estas secciones:</p>${buildListHtml(missingMandatorySections)}`,
                            "warning");

                        return;
                    }

                    if (!direccionValidada && !asumirDireccionCheck.checked) {
                        event.preventDefault();
                        setDireccionMessage("warning", "Debes validar la dirección o marcar 'Asumir dirección errada y continuar'.");
                        showFeedbackModal(
                            "Validacion pendiente",
                            "<p class=\"mb-0\">Debes validar la dirección o marcar 'Asumir dirección errada y continuar'.</p>",
                            "warning");
                    }
                });
            }

            if (municipioSelect) {
                municipioSelect.addEventListener("change", async () => {
                    const municipio = municipioSelect.value || "";
                    lastValidationDistrict = "";
                    if (barrioSelect) {
                        barrioSelect.value = "";
                    }

                    await applyMunicipalityDefaults(municipio, "", "");
                    await loadBarriosByMunicipio(municipio, "a", "");
                });
            }

            if (barrioSelect) {
                barrioSelect.addEventListener("change", async () => {
                    const municipio = municipioSelect ? municipioSelect.value : "";
                    const barrio = barrioSelect.value || "";
                    await applyMunicipalityDefaults(municipio, barrio, lastValidationDistrict);
                });
            }

            const sanitizePhoneInput = (input) => {
                if (!input) {
                    return;
                }

                input.value = (input.value || "").replace(/\D/g, "").slice(0, 10);
            };

            const sanitizeDaysInput = (input) => {
                if (!input) {
                    return;
                }

                const digits = (input.value || "").replace(/\D/g, "").slice(0, 3);
                if (!digits) {
                    input.value = "";
                    return;
                }

                const value = Math.min(999, Math.max(1, Number.parseInt(digits, 10)));
                input.value = String(value);
            };

            const formatDateInputValue = (date) => {
                const year = date.getFullYear();
                const month = String(date.getMonth() + 1).padStart(2, "0");
                const day = String(date.getDate()).padStart(2, "0");
                return `${year}-${month}-${day}`;
            };

            const addDaysToDateInputValue = (value, days) => {
                const match = String(value || "").match(/^(\d{4})-(\d{2})-(\d{2})$/);
                if (!match) {
                    return "";
                }

                const year = Number.parseInt(match[1], 10);
                const month = Number.parseInt(match[2], 10) - 1;
                const day = Number.parseInt(match[3], 10);
                const date = new Date(year, month, day);

                if (
                    date.getFullYear() !== year
                    || date.getMonth() !== month
                    || date.getDate() !== day
                ) {
                    return "";
                }

                date.setDate(date.getDate() + days);
                return formatDateInputValue(date);
            };

            const syncFechaProximoCambioSonda = () => {
                if (!fechaUltimoCambioSondaInput || !fechaProximoCambioSondaInput) {
                    return;
                }

                fechaProximoCambioSondaInput.value = addDaysToDateInputValue(fechaUltimoCambioSondaInput.value, 21);
            };

            const isEstadoAlta = () => String(estadoSelect ? estadoSelect.value : "")
                .toLowerCase()
                .includes("alta");

            const clearGestionAltaFields = () => {
                if (fechaAltaInput) {
                    fechaAltaInput.value = "";
                }

                if (nombreQuienGestionaAltaInput) {
                    nombreQuienGestionaAltaInput.value = "";
                }
            };

            const syncGestionAltaVisibility = () => {
                const showGestionAlta = isEstadoAlta();

                if (gestionAltaTabLink) {
                    gestionAltaTabLink.classList.toggle("d-none", !showGestionAlta);
                    gestionAltaTabLink.setAttribute("aria-hidden", showGestionAlta ? "false" : "true");
                    gestionAltaTabLink.tabIndex = showGestionAlta ? 0 : -1;
                }

                if (gestionAltaPane) {
                    gestionAltaPane.classList.toggle("d-none", !showGestionAlta);
                }

                if (showGestionAlta) {
                    return;
                }

                clearGestionAltaFields();

                if (gestionAltaPane && gestionAltaPane.classList.contains("active")) {
                    openSectionTab("tab-plan-manejo-link");
                }
            };

            const calculatePrincipalDailyDose = (frequency) => {
                const normalized = String(frequency || "").trim().toUpperCase();

                if (!normalized) {
                    return "";
                }

                if (normalized === "NO APLICA") {
                    return "NO APLICA";
                }

                if (normalized === "INFUSION CONTINUA") {
                    return "1";
                }

                const match = normalized.match(/^CADA\s+(\d+)\s+HORAS$/);
                if (!match) {
                    return "";
                }

                const hours = Number.parseInt(match[1], 10);
                if (!Number.isFinite(hours) || hours <= 0) {
                    return "";
                }

                return String(Math.max(1, Math.floor(24 / hours)));
            };

            const syncPrincipalDailyDose = () => {
                if (!frecuenciaAdministracionMxPrincipalSelect || !numeroDosisDiaMedicamentoPrincipalInput) {
                    return;
                }

                numeroDosisDiaMedicamentoPrincipalInput.value = calculatePrincipalDailyDose(frecuenciaAdministracionMxPrincipalSelect.value);
                syncAplicacionesTotales();
            };

            const syncAdditionalMedicationDailyDose = (frequencySelect, doseInput) => {
                if (!frequencySelect || !doseInput) {
                    return;
                }

                doseInput.value = calculatePrincipalDailyDose(frequencySelect.value);
                syncAplicacionesTotales();
            };

            const syncAllMedicationDailyDoses = () => {
                syncPrincipalDailyDose();
                syncAdditionalMedicationDailyDose(frecuenciaMedicamento2Select, numeroDosisMedicamento2Select);
                syncAdditionalMedicationDailyDose(frecuenciaMedicamento3Select, numeroDosisMedicamento3Select);
                syncAdditionalMedicationDailyDose(frecuenciaMedicamento4Select, numeroDosisMedicamento4Select);
                syncAdditionalMedicationDailyDose(frecuenciaMedicamento5Select, numeroDosisMedicamento5Select);
                syncAdditionalMedicationDailyDose(frecuenciaMedicamento6Select, numeroDosisMedicamento6Select);
            };

            const isMedicationAdministrationEnabled = () => {
                if (!administracionMedicamentosSelect) {
                    return false;
                }

                return String(administracionMedicamentosSelect.value || "").trim().toLowerCase() === "si";
            };

            const isServiciosComplementariosEnabled = () => {
                if (!requiereServiciosComplementariosSelect) {
                    return false;
                }

                return String(requiereServiciosComplementariosSelect.value || "").trim().toLowerCase() === "si";
            };

            const parseIsoDateInputValue = (value) => {
                const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(String(value || "").trim());
                if (!match) {
                    return null;
                }

                const year = Number.parseInt(match[1], 10);
                const month = Number.parseInt(match[2], 10);
                const day = Number.parseInt(match[3], 10);
                const date = new Date(year, month - 1, day);
                if (date.getFullYear() !== year || date.getMonth() !== month - 1 || date.getDate() !== day) {
                    return null;
                }

                return date;
            };

            const toIsoDateInputValue = (date) => {
                const year = String(date.getFullYear()).padStart(4, "0");
                const month = String(date.getMonth() + 1).padStart(2, "0");
                const day = String(date.getDate()).padStart(2, "0");
                return `${year}-${month}-${day}`;
            };

            const syncFechaFinTratamiento = () => {
                if (!fechaFinTratamientoInput) {
                    return;
                }

                const shouldAutoCalculate = isMedicationAdministrationEnabled();
                fechaFinTratamientoInput.readOnly = shouldAutoCalculate;

                if (!shouldAutoCalculate) {
                    return;
                }

                const startDate = parseIsoDateInputValue(fechaInicioTratamientoInput && fechaInicioTratamientoInput.value ? fechaInicioTratamientoInput.value : "");
                const treatmentDays = Number.parseInt(diasTratamientoIvInput && diasTratamientoIvInput.value ? diasTratamientoIvInput.value : "0", 10);
                if (!startDate || !Number.isFinite(treatmentDays) || treatmentDays < 1) {
                    fechaFinTratamientoInput.value = "";
                    return;
                }

                const endDate = new Date(startDate.getFullYear(), startDate.getMonth(), startDate.getDate());
                endDate.setDate(endDate.getDate() + treatmentDays);
                fechaFinTratamientoInput.value = toIsoDateInputValue(endDate);
            };

            const calculateMedicationApplications = (doseInput, daysInput) => {
                const dose = Number.parseInt(doseInput && doseInput.value ? doseInput.value : "0", 10);
                const days = Number.parseInt(daysInput && daysInput.value ? daysInput.value : "0", 10);

                if (!Number.isFinite(dose) || !Number.isFinite(days) || dose < 1 || days < 1) {
                    return 0;
                }

                return dose * days;
            };

            const calculateMedicationApplicationsByFrequency = (frequency, daysInput) => {
                const days = getMedicationDaysValue(daysInput);
                if (days < 1) {
                    return 0;
                }

                const normalized = String(frequency || "").trim().toUpperCase();
                if (!normalized || normalized === "NO APLICA") {
                    return 0;
                }

                if (normalized === "INFUSION CONTINUA") {
                    return days;
                }

                const match = normalized.match(/^CADA\s+(\d+(?:[.,]\d+)?)\s+HORAS$/);
                if (!match) {
                    return 0;
                }

                const hours = parseRequisitionDecimal(match[1]);
                return hours > 0 ? Math.ceil((days * 24) / hours) : 0;
            };

            const getMedicationDaysValue = (daysInput) => {
                const days = Number.parseInt(daysInput && daysInput.value ? daysInput.value : "0", 10);
                if (!Number.isFinite(days) || days < 1) {
                    return 0;
                }

                return days;
            };

            const isCambioFrecuenciaActivo = () =>
                !!(cambioFrecuenciaAdministracionTtoSelect
                    && String(cambioFrecuenciaAdministracionTtoSelect.value || "").toLowerCase() === "si");

            const getFrequencyForApplications = (medicationNumber, originalFrequency) => {
                if (!isCambioFrecuenciaActivo()
                    || !medicamentoFrecuenciaAjustadaSelect
                    || !frecuenciaAjustadaSelect
                    || medicamentoFrecuenciaAjustadaSelect.value !== String(medicationNumber)) {
                    return originalFrequency || "";
                }

                return frecuenciaAjustadaSelect.value || originalFrequency || "";
            };

            const calculateMedicationApplicationsWithAdjustment = (medicationNumber, originalFrequencySelect, dailyDoseInput, daysInput) => {
                const frequency = getFrequencyForApplications(medicationNumber, originalFrequencySelect ? originalFrequencySelect.value : "");
                const byFrequency = calculateMedicationApplicationsByFrequency(frequency, daysInput);
                return byFrequency > 0 ? byFrequency : calculateMedicationApplications(dailyDoseInput, daysInput);
