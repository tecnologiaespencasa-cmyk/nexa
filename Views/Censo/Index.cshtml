                    const curVal = medicamentoFrecuenciaAjustadaSelect.value;
                    if (!showAdjustment || (curVal && availMap[curVal] === false)) {
                        medicamentoFrecuenciaAjustadaSelect.value = "";
                    }
                    syncSelectPlaceholderState(medicamentoFrecuenciaAjustadaSelect);
