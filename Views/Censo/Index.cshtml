                const days = [getMedicationDaysValue(diasMedicamentoPrincipalInput)];

                if (medicamento2Toggle && medicamento2Toggle.checked) {
                    days.push(getMedicationDaysValue(diasMedicamento2Input));
                }

                if (medicamento3Toggle && medicamento3Toggle.checked) { days.push(getMedicationDaysValue(diasMedicamento3Input)); }
                if (medicamento4Toggle && medicamento4Toggle.checked) { days.push(getMedicationDaysValue(diasMedicamento4Input)); }
                if (medicamento5Toggle && medicamento5Toggle.checked) { days.push(getMedicationDaysValue(diasMedicamento5Input)); }
                if (medicamento6Toggle && medicamento6Toggle.checked) { days.push(getMedicationDaysValue(diasMedicamento6Input)); }

