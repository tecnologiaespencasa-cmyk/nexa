            const collectKardexPayload = () => {
                const fields = {};
                document.querySelectorAll("#censoKardexModal [data-kardex-field]").forEach((control) => {
                    fields[control.dataset.kardexField] = control.value || "";
                });
                const medRows = Array.from(document.querySelectorAll("#censoKardexModal [data-kardex-med-row]"))
                    .map((rowElement) => {
                        const rowData = { row: rowElement.dataset.kardexMedRow };
                        rowElement.querySelectorAll("[data-kardex-med-field]").forEach((control) => {
                            rowData[control.dataset.kardexMedField] = control.value || "";
                        });
                        return rowData;
                    });
                return { fields, medRows };
            };

            const loadKardexPayload = (payload) => {
                if (!payload) return;
                if (payload.fields) {
                    Object.entries(payload.fields).forEach(([key, value]) => {
                        const control = document.querySelector(`#censoKardexModal [data-kardex-field='${key}']`);
                        if (control) control.value = value || "";
                    });
                }
                if (Array.isArray(payload.medRows)) {
                    payload.medRows.forEach((rowData) => {
                        const row = rowData.row;
                        Object.entries(rowData).forEach(([field, value]) => {
                            if (field === "row") return;
                            const control = document.querySelector(`#censoKardexModal [data-kardex-med-row='${row}'] [data-kardex-med-field='${field}']`);
                            if (control) control.value = value || "";
                        });
                    });
                }
            };

            const loadRequisitionPayload = (payload) => {
                if (!payload) return;
                if (payload.fields) {
                    Object.entries(payload.fields).forEach(([key, value]) => {
                        const control = document.querySelector(`#censoKardexModal [data-requisition-field='${key}']`);
                        if (control) control.value = value || "";
                    });
                }
                if (Array.isArray(payload.rows)) {
                    payload.rows.forEach((rowData, index) => {
                        const rowNum = index + 1;
                        Object.entries(rowData).forEach(([field, value]) => {
                            const control = document.querySelector(`#censoKardexModal [data-requisition-row='${rowNum}'] [data-requisition-item-field='${field}']`);
                            if (control) control.value = value || "";
                        });
                    });
                }
            };

            const kardexModal = document.getElementById("censoKardexModal");
            if (kardexModal) {
                kardexModal.addEventListener("show.bs.modal", async () => {
                    const recordId = Number(editingRecordIdInput?.value || "0") || 0;
                    let savedKardex = null;
                    let savedRequisicion = null;
                    if (recordId > 0) {
                        try {
                            const resp = await fetch(`${obtenerDocumentosUrl}?id=${recordId}`);
                            if (resp.ok) {
                                const saved = await resp.json();
                                savedKardex = saved.kardexJson ? JSON.parse(saved.kardexJson) : null;
                                savedRequisicion = saved.requisicionJson ? JSON.parse(saved.requisicionJson) : null;
                            }
                        } catch { /* fallback to form sync */ }
                    }
                    if (savedKardex) loadKardexPayload(savedKardex); else syncKardexSheet();
                    if (savedRequisicion) loadRequisitionPayload(savedRequisicion); else syncRequisitionSheet();
                    loadAdjuntos(recordId);
                    if (adjuntoUploadStatus) adjuntoUploadStatus.textContent = "";
                });
