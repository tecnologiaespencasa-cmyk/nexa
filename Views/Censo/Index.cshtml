@model CensoReceptionViewModel
@using IntranetPrueba.Data.Entities
@using System.Text.Json
@section Styles
{
    <link rel="stylesheet" href="~/css/censo.css" asp-append-version="true" />
}
@{
    ViewData["Title"] = "Censo";
    var hasNursingAssistants = Model.NursingAssistantOptions.Any();
    var successMessage = TempData["SuccessMessage"] as string;
    var saveErrorMessages = ViewData.ModelState.Values
        .SelectMany(x => x.Errors)
        .Select(x => x.ErrorMessage?.Trim())
        .Where(x => !string.IsNullOrWhiteSpace(x))
        .Cast<string>()
        .Distinct()
        .ToList();
    var missingMandatorySections = ViewData["MissingMandatorySections"] as IReadOnlyList<string> ?? Array.Empty<string>();
    var shouldShowSaveErrorModal = ViewData["ShowSaveErrorModal"] is true && saveErrorMessages.Count > 0;
    var showCurrentPatientBar = !string.IsNullOrWhiteSpace(Model.CedulaFiltro) && Model.EditingRecordId.HasValue;
    var currentPatientAdmissionAt = Model.FechaIngreso.Date + Model.HoraIngreso;
    var kardexTelefonos = string.Join(" / ", new[] { Model.Telefono1, Model.Telefono2, Model.Telefono3 }
        .Where(x => !string.IsNullOrWhiteSpace(x)));
    var kardexDocumento = string.Join(" ", new[] { Model.TipoIdentificacion, Model.NumeroIdentificacion }
        .Where(x => !string.IsNullOrWhiteSpace(x)));
    var kardexTiempoTratamiento = !string.IsNullOrWhiteSpace(Model.DiasTratamientoIv)
        ? Model.DiasTratamientoIv
        : Model.DiasMedicamentoPrincipal?.ToString(System.Globalization.CultureInfo.InvariantCulture) ?? string.Empty;
    var kardexFechaInicio = Model.FechaInicioTratamiento?.ToString("dd/MM/yyyy") ?? string.Empty;
    var kardexFechaFin = Model.FechaFinTratamiento?.ToString("dd/MM/yyyy") ?? string.Empty;
    var medicamentoCatalogJson = JsonSerializer.Serialize(Model.MedicamentoCatalog);
    var censoColumnOrder = new[]
    {
        nameof(CensoRecord.Id),
        nameof(CensoRecord.Asegurador),
        nameof(CensoRecord.EsProrroga),
        nameof(CensoRecord.FechaIngreso),
        nameof(CensoRecord.HoraIngreso),
        nameof(CensoRecord.FechaRespuesta),
        nameof(CensoRecord.HoraRespuesta),
        nameof(CensoRecord.FechaGestionFarmacia),
        nameof(CensoRecord.HoraGestionFarmacia),
        nameof(CensoRecord.GestionCompletaPendiente),
        nameof(CensoRecord.IndicadorTiempoRespuestaMinutos),
        nameof(CensoRecord.IndicadorTiempoGestionMinutos),
        nameof(CensoRecord.NombrePerfilGestionaCaso),
        nameof(CensoRecord.NombreRecepcionaCaso),
        nameof(CensoRecord.NombreRealizaKardex),
        nameof(CensoRecord.NombrePaciente),
        nameof(CensoRecord.TipoIdentificacion),
        nameof(CensoRecord.NumeroIdentificacion),
        nameof(CensoRecord.CodigoCie10),
        nameof(CensoRecord.DiagnosticoDescriptivo),
        nameof(CensoRecord.FechaNacimiento),
        nameof(CensoRecord.Edad),
        nameof(CensoRecord.CorreoElectronico),
        nameof(CensoRecord.Direccion),
        nameof(CensoRecord.ClasificacionZonaSura),
        nameof(CensoRecord.MunicipioResidencia),
        nameof(CensoRecord.Barrio),
        nameof(CensoRecord.ZonaDireccionSegunMunicipio),
        nameof(CensoRecord.Area),
        nameof(CensoRecord.IpsQueRemite),
        nameof(CensoRecord.VistoBuenoRangoFueraAnexo),
        nameof(CensoRecord.Telefono1),
        nameof(CensoRecord.Telefono2),
        nameof(CensoRecord.Telefono3),
        nameof(CensoRecord.ClasificacionRiesgo),
        nameof(CensoRecord.AdministracionMedicamentos),
        nameof(CensoRecord.NombreMedicamentoPrincipalTratante),
        nameof(CensoRecord.DosisMedicamentoPrincipal),
        nameof(CensoRecord.MedidaMedicamentoPrincipal),
        nameof(CensoRecord.ViaAdministracionMedicamentoPrincipal),
        nameof(CensoRecord.FrecuenciaAdministracionMxPrincipal),
        nameof(CensoRecord.DiasMedicamentoPrincipal),
        nameof(CensoRecord.NumeroDosisDiaMedicamentoPrincipal),
        nameof(CensoRecord.NombreMedicamentoNumero2),
        nameof(CensoRecord.DosisMedicamento2),
        nameof(CensoRecord.MedidaMedicamento2),
        nameof(CensoRecord.ViaAdministracionMedicamento2),
        nameof(CensoRecord.FrecuenciaAdministracionMedicamento2),
        nameof(CensoRecord.DiasMedicamento2),
        nameof(CensoRecord.NumeroDosisMedicamento2),
        nameof(CensoRecord.NombreMedicamentoNumero3),
        nameof(CensoRecord.DosisMedicamento3),
        nameof(CensoRecord.MedidaMedicamento3),
        nameof(CensoRecord.ViaAdministracionMedicamento3),
        nameof(CensoRecord.FrecuenciaAdministracionMedicamento3),
        nameof(CensoRecord.DiasMedicamento3),
        nameof(CensoRecord.NumeroDosisMedicamento3),
        nameof(CensoRecord.AplicacionesTotales),
        nameof(CensoRecord.DiasTratamientoIv),
        nameof(CensoRecord.CambioFrecuenciaAdministracionTto),
        nameof(CensoRecord.FrecuenciaAjustada),
        nameof(CensoRecord.MedicamentoFrecuenciaAjustada),
        nameof(CensoRecord.FechaInicioTratamiento),
        nameof(CensoRecord.FechaFinTratamiento),
        nameof(CensoRecord.FechaPromesaInicioTto),
        nameof(CensoRecord.HoraPromesaInicioTto),
        nameof(CensoRecord.AuxiliarAsignado),
        nameof(CensoRecord.Estado),
        nameof(CensoRecord.AutorizacionEvento),
        nameof(CensoRecord.ResponsableLlamadaBienvenida),
        nameof(CensoRecord.EstadoLlamadaBienvenida),
        nameof(CensoRecord.ObservacionesPlanManejo),
        nameof(CensoRecord.NumeroTelefonoLlamadaBienvenida),
        nameof(CensoRecord.NumeroDiasAutorizado),
        nameof(CensoRecord.RequiereServiciosComplementarios),
        nameof(CensoRecord.ServicioComplementario),
        nameof(CensoRecord.PacienteGestante),
        nameof(CensoRecord.Nebulizaciones),
        nameof(CensoRecord.SistemasPresionNegativaVac),
        nameof(CensoRecord.NutricionParenteral),
        nameof(CensoRecord.NutricionEnteral),
        nameof(CensoRecord.PacienteAnticoagulado),
        nameof(CensoRecord.LaboratorioClinicoProcedimiento),
        nameof(CensoRecord.ClinicaHeridas),
        nameof(CensoRecord.Aislamiento),
        nameof(CensoRecord.TipoAislamiento),
        nameof(CensoRecord.CateterismoOSv),
        nameof(CensoRecord.CateterPicc),
        nameof(CensoRecord.NumeroCalibreSonda),
        nameof(CensoRecord.FechaUltimoCambioSonda),
        nameof(CensoRecord.AuxiliarAsignadoCateterismo),
        nameof(CensoRecord.FechaProximoCambioSonda),
        nameof(CensoRecord.FechaUltimaCuracionPicc),
        nameof(CensoRecord.FechaAlta),
        nameof(CensoRecord.NombreQuienGestionaAlta),
        nameof(CensoRecord.AltaTardia),
        nameof(CensoRecord.FechaPrimerSeguimiento24Horas),
        nameof(CensoRecord.FechaSegundoSeguimiento48Horas),
        nameof(CensoRecord.FechaTercerSeguimiento72Horas),
        nameof(CensoRecord.ObservacionAltaTardia),
        nameof(CensoRecord.NombreQuienRealizaSeguimientoAltaTardia),
        nameof(CensoRecord.PacienteRehospitalizado),
        nameof(CensoRecord.FechaRegistroReporteRehospitalizacion),
        nameof(CensoRecord.FechaRehospitalizacion),
        nameof(CensoRecord.MotivoRehospitalizacion),
        nameof(CensoRecord.AmpliacionMotivoRehospitalizacion),
        nameof(CensoRecord.RemitidoPorRehospitalizacion),
        nameof(CensoRecord.IpsIntramuralRehospitalizacion),
        nameof(CensoRecord.FechaPrimerSeguimientoRehospitalizacion),
        nameof(CensoRecord.FechaSegundoSeguimientoRehospitalizacion),
        nameof(CensoRecord.FechaTercerSeguimientoRehospitalizacion),
        nameof(CensoRecord.FechaAltaHospitalizacion),
        nameof(CensoRecord.ObservacionRehospitalizacion),
        nameof(CensoRecord.FechaNovedadDevolucionProductos),
        nameof(CensoRecord.MotivoNovedadDevolucionProductos),
        nameof(CensoRecord.NotificacionAuxiliarDevolucionProductos),
        nameof(CensoRecord.FechaMaximaDevolucionProductos),
        nameof(CensoRecord.EstadoDevolucionServicioFarmaceutico),
        nameof(CensoRecord.PresentaNovedadKardex),
        nameof(CensoRecord.PresentaNovedadRequisicion),
        nameof(CensoRecord.PresentaNovedadAutorizacion),
        nameof(CensoRecord.DescripcionNovedadDocumentosPaciente),
        nameof(CensoRecord.FechaReporteNovedadDocumentos),
        nameof(CensoRecord.HoraReporteNovedadDocumentos),
        nameof(CensoRecord.HoraGestionSolucionNovedadDocumentos),
        nameof(CensoRecord.CreatedAtUtc)
    };
    var hiddenCensoTableColumns = new HashSet<string>
    {
        nameof(CensoRecord.RequisicionFarmaciaJson),
        nameof(CensoRecord.FarmaciaEnviadoAtUtc),
        nameof(CensoRecord.FarmaciaKardexVistoAtUtc),
        nameof(CensoRecord.FarmaciaRequisicionVistoAtUtc),
        nameof(CensoRecord.FarmaciaNombreRecibe),
        nameof(CensoRecord.FarmaciaFirmaEntregaDataUrl),
        nameof(CensoRecord.FarmaciaFirmaRecibeDataUrl),
        nameof(CensoRecord.FarmaciaFechaHoraRecepcionUtc),
        nameof(CensoRecord.FarmaciaFirmaActualizadaAtUtc)
    };
    var censoTableColumns = typeof(CensoRecord).GetProperties()
        .Where(property => !hiddenCensoTableColumns.Contains(property.Name))
        .Select((property, index) => new
        {
            Property = property,
            OriginalIndex = index,
            PriorityIndex = Array.IndexOf(censoColumnOrder, property.Name)
        })
        .OrderBy(item => item.PriorityIndex >= 0 ? item.PriorityIndex : int.MaxValue)
        .ThenBy(item => item.OriginalIndex)
        .Select(item => item.Property)
        .ToArray();
}

<div class="censo-page @(showCurrentPatientBar ? "censo-page--with-current-patient" : null)">
    <aside class="censo-sidebar">
        <section class="censo-section-strip">
            <div class="censo-section-strip__nav">
                <div class="list-group censo-nav censo-nav--top" id="censo-tab" role="tablist">
                <button class="list-group-item list-group-item-action active censo-nav__item"
                        id="tab-recepcion-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-recepcion"
                        type="button"
                        role="tab"
                        aria-controls="tab-recepcion"
                        aria-selected="true">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <circle cx="9" cy="7" r="3"></circle>
                            <path d="M4 19v-1a4 4 0 0 1 4-4h2a4 4 0 0 1 4 4v1"></path>
                            <path d="M16 8h4"></path>
                            <path d="M18 6v4"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Recepción</span>
                        <span class="censo-nav__title">Recepción del paciente</span>
                        <span class="censo-nav__description">Ingreso, tiempos de respuesta y responsables del caso.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-datos-basicos-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-datos-basicos"
                        type="button"
                        role="tab"
                        aria-controls="tab-datos-basicos"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <rect x="3" y="5" width="18" height="14" rx="3"></rect>
                            <circle cx="9" cy="10" r="2"></circle>
                            <path d="M6.5 15a3.5 3.5 0 0 1 5 0"></path>
                            <path d="M14 9h4"></path>
                            <path d="M14 13h4"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Paciente</span>
                        <span class="censo-nav__title">Datos básicos del paciente</span>
                        <span class="censo-nav__description">Identificación, dirección, ubicación y contacto.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-plan-manejo-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-plan-manejo"
                        type="button"
                        role="tab"
                        aria-controls="tab-plan-manejo"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M9 3h6"></path>
                            <path d="M10 3v2"></path>
                            <path d="M14 3v2"></path>
                            <rect x="5" y="5" width="14" height="16" rx="3"></rect>
                            <path d="M8 11h8"></path>
                            <path d="M8 15h5"></path>
                            <path d="M8 8h2"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Tratamiento</span>
                        <span class="censo-nav__title">Plan de manejo</span>
                        <span class="censo-nav__description">Riesgo, tratamiento, seguimiento y apoyos.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-gestion-alta-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-gestion-alta"
                        type="button"
                        role="tab"
                        aria-controls="tab-gestion-alta"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M12 3l7 3v5c0 4.25-2.6 8.1-7 10-4.4-1.9-7-5.75-7-10V6l7-3z"></path>
                            <path d="M9.5 12.5l1.8 1.8 3.7-4"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Cierre</span>
                        <span class="censo-nav__title">Gestión de alta</span>
                        <span class="censo-nav__description">Fecha de alta y responsable del cierre.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-seguimiento-alta-tardia-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-seguimiento-alta-tardia"
                        type="button"
                        role="tab"
                        aria-controls="tab-seguimiento-alta-tardia"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <circle cx="12" cy="12" r="9"></circle>
                            <path d="M12 7v5l3 2"></path>
                            <path d="M9 3l1.5 2"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Seguimiento</span>
                        <span class="censo-nav__title">Seguimiento alta tardia</span>
                        <span class="censo-nav__description">Trazabilidad a 24, 48 y 72 horas.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-seguimiento-hospitalizacion-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-seguimiento-hospitalizacion"
                        type="button"
                        role="tab"
                        aria-controls="tab-seguimiento-hospitalizacion"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M4 20V7a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v13"></path>
                            <path d="M9 20v-4h6v4"></path>
                            <path d="M10 9h4"></path>
                            <path d="M12 7v4"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Hospitalización</span>
                        <span class="censo-nav__title">Seguimiento hospitalización</span>
                        <span class="censo-nav__description">Rehospitalización, IPS y observaciones.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-devolucion-productos-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-devolucion-productos"
                        type="button"
                        role="tab"
                        aria-controls="tab-devolucion-productos"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M9 7H5v4"></path>
                            <path d="M5 11a7 7 0 1 0 2-4.9L9 7"></path>
                            <path d="M19 13h-4v4"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Devolución</span>
                        <span class="censo-nav__title">Devolución de productos</span>
                        <span class="censo-nav__description">Novedades, notificaciones y estado farmacéutico.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item"
                        id="tab-novedad-documentos-link"
                        data-bs-toggle="list"
                        data-bs-target="#tab-novedad-documentos"
                        type="button"
                        role="tab"
                        aria-controls="tab-novedad-documentos"
                        aria-selected="false">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                            <path d="M14 3v5h5"></path>
                            <path d="M9 13h6"></path>
                            <path d="M9 17h6"></path>
                            <path d="M9 9h1"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Documentos</span>
                        <span class="censo-nav__title">Novedad documental</span>
                        <span class="censo-nav__description">Hallazgos, tiempos de reporte y gestión.</span>
                    </span>
                </button>

                <button class="list-group-item list-group-item-action censo-nav__item @(!Model.EditingRecordId.HasValue ? "censo-nav__item--locked" : null)"
                        id="tab-prorroga-link"
                        data-bs-toggle="@(Model.EditingRecordId.HasValue ? "list" : null)"
                        data-bs-target="@(Model.EditingRecordId.HasValue ? "#tab-prorroga" : null)"
                        type="button"
                        role="tab"
                        aria-controls="tab-prorroga"
                        aria-selected="false"
                        title="@(!Model.EditingRecordId.HasValue ? "Guarda el paciente (secciones 1, 2 y 3) para acceder a esta sección" : null)">
                    <span class="censo-nav__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M9 3h6l2 4H7z"></path>
                            <rect x="3" y="7" width="18" height="13" rx="2"></rect>
                            <path d="M9 13h6"></path>
                            <path d="M9 17h4"></path>
                        </svg>
                    </span>
                    <span class="censo-nav__content">
                        <span class="censo-nav__eyebrow">Pr&oacute;rroga</span>
                        <span class="censo-nav__title">Pr&oacute;rroga o cambio</span>
                        <span class="censo-nav__description">Medicamentos, fechas y auxiliar de la pr&oacute;rroga.</span>
                        @if (!Model.EditingRecordId.HasValue)
                        {
                            <span class="censo-nav__lock-hint">Disponible al guardar el paciente</span>
                        }
                        @if (Model.EsProrroga)
                        {
                            <span class="censo-nav__badge">Pr&oacute;rroga activa</span>
                        }
                    </span>
                </button>
                </div>
            </div>
            <div class="censo-section-strip__tools">
                <form method="get" asp-action="Index" class="censo-filter-panel">
                    <h2 class="censo-filter-panel__title">Filtros r&aacute;pidos</h2>
                    <label for="cedulaFiltroInput" class="form-label censo-filter-panel__label">Buscar por documento</label>
                    <div class="censo-filter-panel__input-wrap">
                        <input class="form-control censo-filter-panel__input" id="cedulaFiltroInput" name="cedulaPaciente" value="@Model.CedulaFiltro" inputmode="numeric" maxlength="20" placeholder="Ingrese documento" />
                        <span class="censo-filter-panel__search-icon" aria-hidden="true">
                            <svg viewBox="0 0 24 24" focusable="false">
                                <circle cx="11" cy="11" r="7"></circle>
                                <path d="m20 20-3.5-3.5"></path>
                            </svg>
                        </span>
                    </div>
                    <div class="censo-filter-panel__actions">
                        <button type="submit" class="btn btn-outline-primary censo-filter-panel__button" id="buscarCedulaBtn">Buscar</button>
                        <a class="btn btn-outline-secondary censo-filter-panel__button" asp-action="Index" id="limpiarCedulaBtn">Limpiar</a>
                    </div>
                </form>
            </div>
            <div class="censo-section-strip__actions">
                <a class="btn btn-success btn-sm censo-export-button" asp-action="ExportarExcel">
                    <span class="censo-export-button__icon" aria-hidden="true">
                        <svg viewBox="0 0 24 24" focusable="false">
                            <path d="M14 3H7a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V8z"></path>
                            <path d="M14 3v5h5"></path>
                            <path d="M9 10l4 6"></path>
                            <path d="M13 10l-4 6"></path>
                        </svg>
                    </span>
                    <span>Exportar censo</span>
                </a>
            </div>
        </section>
    </aside>

    @if (showCurrentPatientBar)
    {
        <section class="censo-current-patient" aria-label="Paciente actual">
            <div class="censo-current-patient__avatar" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <circle cx="12" cy="8" r="4"></circle>
                    <path d="M4 21a8 8 0 0 1 16 0"></path>
                </svg>
            </div>

            <div class="censo-current-patient__identity">
                <span class="censo-current-patient__label">Paciente actual</span>
                <strong>@Model.NombrePaciente</strong>
                @if (Model.TieneProrrogaActiva)
                {
                    <span class="badge bg-warning text-dark ms-1">PRÓRROGA</span>
                }
                @if (!string.IsNullOrWhiteSpace(Model.Estado))
                {
                    <span class="censo-current-patient__status">@Model.Estado</span>
                }
            </div>

            <div class="censo-current-patient__item">
                <span class="censo-current-patient__label">Tipo ID</span>
                <strong>@Model.TipoIdentificacion</strong>
            </div>

            <div class="censo-current-patient__item">
                <span class="censo-current-patient__label">Documento</span>
                <strong>@Model.NumeroIdentificacion</strong>
            </div>

            <div class="censo-current-patient__item">
                <span class="censo-current-patient__label">Fecha de ingreso</span>
                <strong>
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <rect x="4" y="5" width="16" height="15" rx="2"></rect>
                        <path d="M8 3v4"></path>
                        <path d="M16 3v4"></path>
                        <path d="M4 10h16"></path>
                    </svg>
                    @currentPatientAdmissionAt.ToString("dd/MM/yyyy hh:mm tt", System.Globalization.CultureInfo.InvariantCulture).ToLowerInvariant()
                </strong>
            </div>

            <div class="censo-current-patient__actions">
                <div class="dropdown">
