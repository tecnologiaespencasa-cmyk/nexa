                    set("prorrogaFechaInicio", data.fechaInicioTratamiento);
                    set("prorrogaFechaFin", data.fechaFinTratamiento);
                    set("prorrogaFechaPromesa", data.fechaPromesaInicioTto);
                    set("prorrogaHoraDesde", data.horaPromesaDesde);
                    set("prorrogaHoraHasta", data.horaPromesaHasta);
                    set("prorrogaAuxiliarAsignado", data.auxiliarAsignado);
                    if (data.tipoProrroga) {
                        const tipoRadio = document.querySelector(`input[name='prorroga-tipo'][value='${data.tipoProrroga}']`);
                        if (tipoRadio) tipoRadio.checked = true;
                    }
                    document.getElementById("prorrogaExtensionContainer")?.classList.toggle("d-none", data.tipoProrroga !== "extension");
                    set("prorrogaNumeroDiasExtension", data.numeroDiasExtension);
                    const notifEl = document.getElementById("prorrogaNotificadoAsegurador");
                    if (notifEl) notifEl.checked = !!data.notificadoAsegurador;
                };

                document.querySelectorAll("input[name='prorroga-tipo']").forEach((radio) => {
                    radio.addEventListener("change", () => {
                        const isExtension = document.querySelector("input[name='prorroga-tipo']:checked")?.value === "extension";
                        document.getElementById("prorrogaExtensionContainer")?.classList.toggle("d-none", !isExtension);
                    });
