                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <section class="censo-document-pane active" id="censoKardexPane" data-censo-document-pane="kardex" role="tabpanel" aria-labelledby="censoKardexTabButton">
