                if (medicamentoFrecuenciaAjustadaSelect) {
                    const med2Avail = !!(medicamento2Toggle && medicamento2Toggle.checked);
                    const med3Avail = !!(medicamento3Toggle && medicamento3Toggle.checked);
                    const med4Avail = !!(medicamento4Toggle && medicamento4Toggle.checked);
                    const med5Avail = !!(medicamento5Toggle && medicamento5Toggle.checked);
                    const med6Avail = !!(medicamento6Toggle && medicamento6Toggle.checked);
                    const availMap = { "2": med2Avail, "3": med3Avail, "4": med4Avail, "5": med5Avail, "6": med6Avail };
                    Array.from(medicamentoFrecuenciaAjustadaSelect.options).forEach((option) => {
                        if (availMap[option.value] !== undefined) {
                            option.hidden = !availMap[option.value];
                            option.disabled = !availMap[option.value];
                        }
