                const wireProrrogaMedToggle = (toggle, container) => {
                    if (toggle) {
                        toggle.addEventListener("change", () => {
                            container?.classList.toggle("d-none", !toggle.checked);
                            syncProrrogaAplicaciones();
                        });
                    }
                };
                wireProrrogaMedToggle(prorrogaMed2Toggle, prorrogaMed2Container);
                wireProrrogaMedToggle(prorrogaMed3Toggle, prorrogaMed3Container);
                wireProrrogaMedToggle(prorrogaMed4Toggle, prorrogaMed4Container);
                wireProrrogaMedToggle(prorrogaMed5Toggle, prorrogaMed5Container);
                wireProrrogaMedToggle(prorrogaMed6Toggle, prorrogaMed6Container);

                ["prorrogaFrecuenciaMedPrincipal", "prorrogaDiasMedPrincipal",
                 "prorrogaFrecuenciaMed2", "prorrogaDiasMed2",
                 "prorrogaFrecuenciaMed3", "prorrogaDiasMed3",
                 "prorrogaFrecuenciaMed4", "prorrogaDiasMed4",
                 "prorrogaFrecuenciaMed5", "prorrogaDiasMed5",
                 "prorrogaFrecuenciaMed6", "prorrogaDiasMed6"].forEach((id) => {
                    document.getElementById(id)?.addEventListener("change", syncProrrogaAplicaciones);
                    document.getElementById(id)?.addEventListener("input", syncProrrogaAplicaciones);
                });

                if (prorrogaFechaInicioInput) {
                    prorrogaFechaInicioInput.addEventListener("change", syncProrrogaFechaFin);
                }

                if (prorrogaTabLink) {
                    prorrogaTabLink.addEventListener("show.bs.tab", async () => {
                        if (prorrogaDataLoaded) return;
                        prorrogaDataLoaded = true;
                        const recordId = Number(editingRecordIdInput?.value || "0") || 0;
                        if (recordId <= 0) return;
                        try {
                            const resp = await fetch(`${obtenerDocumentosUrl}?id=${recordId}`);
                            if (resp.ok) {
                                const saved = await resp.json();
                                if (saved.prorrogaJson) {
                                    loadProrrogaPayload(JSON.parse(saved.prorrogaJson));
                                }
                            }
                        } catch { }
                    });
                }

                if (guardarProrrogaBtn) {
                    guardarProrrogaBtn.addEventListener("click", async () => {
                        const recordId = Number(editingRecordIdInput?.value || "0") || 0;
                        if (recordId <= 0) {
                            showFeedbackModal("Sin paciente activo", "<p class=\"mb-0\">Primero guarda el paciente antes de guardar la prórroga.</p>", "warning");
                            return;
                        }
                        guardarProrrogaBtn.disabled = true;
                        if (prorrogaGuardadoStatus) prorrogaGuardadoStatus.textContent = "Guardando...";
                        try {
                            const formData = new FormData();
                            formData.append("id", String(recordId));
                            formData.append("prorrogaJson", JSON.stringify(collectProrrogaPayload()));
                            if (csrfTokenInput) formData.append("__RequestVerificationToken", csrfTokenInput.value);
                            const resp = await fetch(guardarProrrogaUrl, { method: "POST", body: formData });
                            const result = await resp.json().catch(() => ({}));
                            if (!resp.ok) {
                                showFeedbackModal("No se pudo guardar", `<p class="mb-0">${escapeHtml(result.message || "Error al guardar la prórroga.")}</p>`, "danger");
                                if (prorrogaGuardadoStatus) prorrogaGuardadoStatus.textContent = "";
                                return;
                            }
                            if (prorrogaGuardadoStatus) prorrogaGuardadoStatus.textContent = "Guardado ✓";
                            window.setTimeout(() => { if (prorrogaGuardadoStatus) prorrogaGuardadoStatus.textContent = ""; }, 3000);
                        } catch {
                            showFeedbackModal("Error de conexión", "<p class=\"mb-0\">No se pudo conectar al servidor.</p>", "danger");
                            if (prorrogaGuardadoStatus) prorrogaGuardadoStatus.textContent = "";
                        } finally {
                            guardarProrrogaBtn.disabled = false;
                        }
                    });
                }
            }
            // ── End prorroga section ──────────────────────────────────────

            if (shouldShowSaveErrorModal) {
                const normalizedErrors = Array.from(new Set((serverErrorMessages || [])
                    .map((error) => String(error || "").trim())
                    .filter((error) => error.length > 0)));
                const missingSections = Array.from(new Set((serverMissingMandatorySections || [])
                    .map((section) => String(section || "").trim())
                    .filter((section) => section.length > 0)));

                let bodyHtml = "";
                if (missingSections.length > 0) {
                    bodyHtml += `<p class="mb-2">Faltan secciones obligatorias por diligenciar:</p>${buildListHtml(missingSections)}`;
                }

                const generalErrors = normalizedErrors
                    .filter((error) => !error.toLowerCase().startsWith("para guardar el censo debes completar"))
                    .slice(0, 10);

                if (generalErrors.length > 0) {
                    bodyHtml += `${bodyHtml ? "<p class=\"mt-3 mb-2\">Revisa tambien:</p>" : "<p class=\"mb-2\">Se encontraron errores de validacion:</p>"}${buildListHtml(generalErrors)}`;
                }

                if (!bodyHtml) {
                    bodyHtml = "<p class=\"mb-0\">No se pudo guardar el registro. Revisa la información del formulario.</p>";
                }

                showFeedbackModal("No se pudo guardar el censo", bodyHtml, "danger");

                if (missingSections.length > 0) {
                    const firstMissingSection = mandatorySectionsConfig.find((section) => section.name === missingSections[0]);
                    if (firstMissingSection) {
                        openSectionTab(firstMissingSection.tabLinkId);
                    }
                }
            }
        })();
    </script>
}
