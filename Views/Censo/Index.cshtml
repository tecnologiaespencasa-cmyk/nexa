            const renderAdjuntos = (adjuntos) => {
                if (!adjuntosListEl) return;
                adjuntosListEl.innerHTML = "";
                if (!adjuntos || adjuntos.length === 0) {
                    adjuntosListEl.innerHTML = `<li class="list-group-item py-1 small text-muted">Sin adjuntos</li>`;
                    return;
                }
                adjuntos.forEach((adj) => {
                    const li = document.createElement("li");
                    li.className = "list-group-item d-flex align-items-center justify-content-between py-1 px-2 small";
                    li.innerHTML = `
                        <a href="${descargarAdjuntoUrl}?adjuntoId=${adj.id}" target="_blank" class="text-truncate me-2" style="max-width:260px" title="${escapeHtml(adj.fileName)}">${escapeHtml(adj.fileName)}</a>
