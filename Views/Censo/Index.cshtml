                    tieneQuintoMedicamento: !!(prorrogaMed5Toggle?.checked),
                    nombreMedicamentoNumero5: getProrrogaInputValue("prorrogaNombreMed5"),
                    dosisMedicamento5: getProrrogaInputValue("prorrogaDosisMed5"),
                    medidaMedicamento5: getProrrogaInputValue("prorrogaMedidaMed5"),
                    viaAdministracionMedicamento5: getProrrogaInputValue("prorrogaViaMed5"),
