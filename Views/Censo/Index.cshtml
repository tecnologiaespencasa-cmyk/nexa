                        frequency: getFormValue("FrecuenciaAdministracionMxPrincipal"),
                        dailyDoses: getFormValue("NumeroDosisDiaMedicamentoPrincipal"),
                        days: getFormValue("DiasMedicamentoPrincipal"),
                        startDate: fechaInicio,
                        endDate: fechaFin
                    },
                    {
                        name: getFormValue("NombreMedicamentoNumero2"),
                        dose: getFormValue("DosisMedicamento2"),
