            };

            const setRequisitionRowField = (row, field, value) => {
                const control = document.querySelector(`#censoKardexModal [data-requisition-row='${row}'] [data-requisition-item-field='${field}']`);
                if (control) {
                    control.value = value || "";
                }
            };

            const parseRequisitionDecimal = (value) => {
                const normalized = String(value || "")
                    .replace(/,/g, ".")
                    .replace(/[^0-9.]/g, "");
                const parsed = Number.parseFloat(normalized);
                return Number.isFinite(parsed) ? parsed : 0;
            };

            const formatRequisitionQuantity = (value) => {
                const numeric = Number(value);
                if (!Number.isFinite(numeric) || numeric <= 0) {
                    return "";
                }

                return Number.isInteger(numeric)
                    ? String(numeric)
                    : String(Math.round(numeric * 100) / 100);
            };

            const parseFrequencyPerDay = (frequency) => {
                const normalized = String(frequency || "").toUpperCase();
                const numberMatch = normalized.match(/(\d+(?:[.,]\d+)?)/);
                const number = numberMatch ? parseRequisitionDecimal(numberMatch[1]) : 0;
                if (normalized.includes("24") && normalized.includes("HORA")) {
                    return 1;
                }

                if (normalized.includes("12") && normalized.includes("HORA")) {
                    return 2;
                }

                if (normalized.includes("8") && normalized.includes("HORA")) {
                    return 3;
                }

                if (normalized.includes("6") && normalized.includes("HORA")) {
                    return 4;
                }

                if (normalized.includes("4") && normalized.includes("HORA")) {
                    return 6;
                }

                if (number > 0 && normalized.includes("HORA")) {
                    return 24 / number;
                }

                if (normalized.includes("DIA") || normalized.includes("DIARIA")) {
                    return number > 0 ? number : 1;
                }

                return number;
            };

            const calculateMedicationRequisitionQuantity = (medication) => {
                const dose = Math.max(parseRequisitionDecimal(medication.dose) || 1, 1);
                const dailyDoses = parseRequisitionDecimal(medication.dailyDoses) || parseFrequencyPerDay(medication.frequency);
                const days = parseRequisitionDecimal(medication.days);
                return dose * dailyDoses * days;
            };

            const calculateEveryThreeDaysQuantity = (daysValue, minimumTwoWhenLessThanOne = false) => {
                const days = parseRequisitionDecimal(daysValue);
                if (days <= 0) {
                    return minimumTwoWhenLessThanOne ? 2 : 0;
                }

                const raw = days / 3;
                if (minimumTwoWhenLessThanOne && raw < 1) {
                    return 2;
                }

                return Math.ceil(raw);
            };

            const hasRequisitionMedication = (name) => {
                const value = String(name || "").trim();
                return value.length > 0 && value.toLowerCase() !== "no";
            };

            const getRequisitionMedications = () => {
                const fechaInicio = formatDateForKardex(getFormValue("FechaInicioTratamiento"));
                const fechaFin = formatDateForKardex(getFormValue("FechaFinTratamiento"));
                return [
                    {
                        name: getFormValue("NombreMedicamentoPrincipalTratante"),
