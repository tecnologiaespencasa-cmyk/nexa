                        <div class="censo-kardex-sheet__meta">
                            <label>C&oacute;digo:<input data-kardex-field="codigoFormato" value="FO-SEF-07" /></label>
                            <label>Versi&oacute;n:<input data-kardex-field="versionFormato" value="04" /></label>
                            <label>pagina:<input data-kardex-field="paginaFormato" value="1 de 1" /></label>
                            <label>Fecha:<input data-kardex-field="fechaFormato" value="01/05/2026" /></label>
                        </div>
                    </div>

                    <div class="censo-kardex-patient-table">
