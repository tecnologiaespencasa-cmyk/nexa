            syncGestionAltaVisibility();

            const normalizeCie10InputValue = (value) => {
                const source = String(value || "").toUpperCase().replace(/[^A-Z0-9]/g, "");
                if (!source) {
                    return "";
                }

                const firstLetterIndex = source.search(/[A-Z]/);
                if (firstLetterIndex < 0) {
                    return "";
                }

                const trimmed = source.slice(firstLetterIndex);
                const letter = trimmed[0];
                const digits = trimmed.slice(1).replace(/\D/g, "").slice(0, 3);
                return `${letter}${digits}`;
            };

            const clearDiagnostico = () => {
                if (diagnosticoDescriptivoInput) {
                    diagnosticoDescriptivoInput.value = "";
                }
            };

            const lookupDiagnosticoByCie10 = async (codigo) => {
                if (!codigo || codigo.length !== 4 || !/^[A-Z][0-9]{3}$/.test(codigo)) {
                    lastCie10Lookup = "";
                    clearDiagnostico();
                    return;
                }

                if (codigo === lastCie10Lookup && diagnosticoDescriptivoInput && diagnosticoDescriptivoInput.value) {
                    return;
                }

                lastCie10Lookup = codigo;
                try {
                    const response = await fetch(`${buscarDiagnosticoCie10Url}?codigo=${encodeURIComponent(codigo)}`);
                    if (!response.ok) {
                        clearDiagnostico();
                        return;
                    }

                    const data = await response.json();
                    if (data && data.found && diagnosticoDescriptivoInput) {
                        diagnosticoDescriptivoInput.value = data.diagnostico || "";
                        return;
                    }

                    clearDiagnostico();
                } catch {
                    clearDiagnostico();
                }
            };

            if (codigoCie10Input) {
                const syncCie10Input = () => {
                    const normalized = normalizeCie10InputValue(codigoCie10Input.value);
                    if (codigoCie10Input.value !== normalized) {
                        codigoCie10Input.value = normalized;
                    }

                    if (cie10LookupTimer) {
                        clearTimeout(cie10LookupTimer);
                    }

                    if (normalized.length === 4) {
                        cie10LookupTimer = setTimeout(() => {
                            lookupDiagnosticoByCie10(normalized);
                        }, 200);
                    } else {
                        lastCie10Lookup = "";
                        clearDiagnostico();
                    }
                };

                codigoCie10Input.addEventListener("input", syncCie10Input);
                codigoCie10Input.addEventListener("blur", () => lookupDiagnosticoByCie10(normalizeCie10InputValue(codigoCie10Input.value)));
                syncCie10Input();
            }

            const switchInput = document.getElementById("gestionCompletaSwitch");
            const statusText = document.getElementById("gestionEstadoTexto");
            if (switchInput && statusText) {
                const syncStatus = () => {
                    statusText.textContent = switchInput.checked ? "Completa" : "Pendiente";
                };

                const showAuxiliarAsignadoRequiredWarning = () => {
                    showFeedbackModal(
                        "Auxiliar asignado requerido",
                        "<p class=\"mb-0\">Para marcar la gesti&oacute;n como completa debes diligenciar el campo Auxiliar asignado en la secci&oacute;n 3.</p>",
                        "warning");
                };

                const focusAuxiliarAsignado = () => {
                    openSectionTab("tab-plan-manejo-link");
                    window.setTimeout(() => {
                        if (auxiliarAsignadoInput) {
                            auxiliarAsignadoInput.focus();
                        }
                    }, 250);
                };

                const requireAuxiliarAsignadoForComplete = (showWarning) => {
                    if (!switchInput.checked || !auxiliarAsignadoInput || String(auxiliarAsignadoInput.value || "").trim()) {
                        return true;
                    }

                    switchInput.checked = false;
                    syncStatus();

                    if (showWarning) {
                        showAuxiliarAsignadoRequiredWarning();
                        focusAuxiliarAsignado();
                    }

                    return false;
                };

                requireAuxiliarAsignadoForComplete(false);
                syncStatus();
                switchInput.addEventListener("change", () => {
                    if (requireAuxiliarAsignadoForComplete(true)) {
                        syncStatus();
                    }
                });

                if (auxiliarAsignadoInput) {
                    auxiliarAsignadoInput.addEventListener("input", () => requireAuxiliarAsignadoForComplete(false));
                    auxiliarAsignadoInput.addEventListener("change", () => requireAuxiliarAsignadoForComplete(false));
                }
            }

            const birthDateInput = document.getElementById("fechaNacimientoInput");
            const ageInput = document.getElementById("edadInput");
            if (birthDateInput && ageInput) {
                const syncAge = () => {
                    if (!birthDateInput.value) {
                        ageInput.value = "0";
                        return;
                    }

                    const birthDate = new Date(birthDateInput.value + "T00:00:00");
                    const today = new Date();
                    let age = today.getFullYear() - birthDate.getFullYear();
                    const hasBirthdayPassed =
                        today.getMonth() > birthDate.getMonth()
                        || (today.getMonth() === birthDate.getMonth() && today.getDate() >= birthDate.getDate());

                    if (!hasBirthdayPassed) {
                        age -= 1;
                    }

                    ageInput.value = Math.max(age, 0);
                };

                syncAge();
                birthDateInput.addEventListener("change", syncAge);
            }

            if (municipioSelect && municipioSelect.value) {
                const barrioInicial = barrioSelect ? (barrioSelect.value || "") : "";

                applyMunicipalityDefaults(municipioSelect.value, barrioInicial, "");
                loadBarriosByMunicipio(municipioSelect.value, "a", barrioInicial);
            }

            if (serverSuccessMessage) {
                showFeedbackModal(
                    "Guardado exitoso",
                    `<p class="mb-0">${escapeHtml(serverSuccessMessage)}</p>`,
                    "success");
            }

            // ── Prorroga section ──────────────────────────────────────────
            {
                const prorrogaTabLink = document.getElementById("tab-prorroga-link");
                const prorrogaMed2Toggle = document.getElementById("prorrogaTieneSegundoMed");
                const prorrogaMed2Container = document.getElementById("prorrogaMed2Container");
                const prorrogaMed3Toggle = document.getElementById("prorrogaTieneTercerMed");
                const prorrogaMed3Container = document.getElementById("prorrogaMed3Container");
                const prorrogaMed4Toggle = document.getElementById("prorrogaTieneCuartoMed");
                const prorrogaMed4Container = document.getElementById("prorrogaMed4Container");
                const prorrogaMed5Toggle = document.getElementById("prorrogaTieneQuintoMed");
                const prorrogaMed5Container = document.getElementById("prorrogaMed5Container");
                const prorrogaMed6Toggle = document.getElementById("prorrogaTieneSextoMed");
                const prorrogaMed6Container = document.getElementById("prorrogaMed6Container");
                const prorrogaAplicacionesInput = document.getElementById("prorrogaAplicacionesTotales");
                const prorrogaDiasIvInput = document.getElementById("prorrogaDiasTratamientoIv");
                const prorrogaFechaInicioInput = document.getElementById("prorrogaFechaInicio");
                const prorrogaFechaFinInput = document.getElementById("prorrogaFechaFin");
                const prorrogaGuardadoStatus = document.getElementById("prorrogaGuardadoStatus");
                const guardarProrrogaBtn = document.getElementById("guardarProrrogaBtn");
                let prorrogaDataLoaded = false;

                const getProrrogaInputValue = (id) => (document.getElementById(id)?.value || "").trim();

                const syncProrrogaDiasIv = () => {
                    if (!prorrogaDiasIvInput) return;
                    const d1 = getMedicationDaysValue(document.getElementById("prorrogaDiasMedPrincipal"));
                    const d2 = prorrogaMed2Toggle?.checked ? getMedicationDaysValue(document.getElementById("prorrogaDiasMed2")) : 0;
                    const d3 = prorrogaMed3Toggle?.checked ? getMedicationDaysValue(document.getElementById("prorrogaDiasMed3")) : 0;
                    const d4 = prorrogaMed4Toggle?.checked ? getMedicationDaysValue(document.getElementById("prorrogaDiasMed4")) : 0;
                    const d5 = prorrogaMed5Toggle?.checked ? getMedicationDaysValue(document.getElementById("prorrogaDiasMed5")) : 0;
                    const d6 = prorrogaMed6Toggle?.checked ? getMedicationDaysValue(document.getElementById("prorrogaDiasMed6")) : 0;
                    const max = Math.max(d1, d2, d3, d4, d5, d6);
                    prorrogaDiasIvInput.value = max > 0 ? String(max) : "";
                };

                const syncProrrogaFechaFin = () => {
                    if (!prorrogaFechaInicioInput || !prorrogaFechaFinInput || !prorrogaDiasIvInput) return;
                    const startDate = parseIsoDateInputValue(prorrogaFechaInicioInput.value);
                    const days = Number.parseInt(prorrogaDiasIvInput.value || "0", 10);
                    if (!startDate || !Number.isFinite(days) || days < 1) {
                        prorrogaFechaFinInput.value = "";
                        return;
                    }
                    const endDate = new Date(startDate);
                    endDate.setDate(endDate.getDate() + days - 1);
                    prorrogaFechaFinInput.value = endDate.toISOString().slice(0, 10);
                };

                const syncProrrogaAplicaciones = () => {
                    if (!prorrogaAplicacionesInput) return;
                    const freq1 = getProrrogaInputValue("prorrogaFrecuenciaMedPrincipal");
                    let total = calculateMedicationApplicationsByFrequency(freq1, document.getElementById("prorrogaDiasMedPrincipal"));
                    if (prorrogaMed2Toggle?.checked) {
                        total += calculateMedicationApplicationsByFrequency(getProrrogaInputValue("prorrogaFrecuenciaMed2"), document.getElementById("prorrogaDiasMed2"));
                    }
                    if (prorrogaMed3Toggle?.checked) {
                        total += calculateMedicationApplicationsByFrequency(getProrrogaInputValue("prorrogaFrecuenciaMed3"), document.getElementById("prorrogaDiasMed3"));
                    }
                    if (prorrogaMed4Toggle?.checked) {
                        total += calculateMedicationApplicationsByFrequency(getProrrogaInputValue("prorrogaFrecuenciaMed4"), document.getElementById("prorrogaDiasMed4"));
                    }
                    if (prorrogaMed5Toggle?.checked) {
                        total += calculateMedicationApplicationsByFrequency(getProrrogaInputValue("prorrogaFrecuenciaMed5"), document.getElementById("prorrogaDiasMed5"));
                    }
                    if (prorrogaMed6Toggle?.checked) {
                        total += calculateMedicationApplicationsByFrequency(getProrrogaInputValue("prorrogaFrecuenciaMed6"), document.getElementById("prorrogaDiasMed6"));
                    }
                    prorrogaAplicacionesInput.value = total > 0 ? String(total) : "";
                    syncProrrogaDiasIv();
                    syncProrrogaFechaFin();
                };

                const collectProrrogaPayload = () => ({
                    tipoProrroga: (document.querySelector("input[name='prorroga-tipo']:checked")?.value || ""),
                    nombreMedicamentoPrincipal: getProrrogaInputValue("prorrogaNombreMedPrincipal"),
                    dosisMedicamentoPrincipal: getProrrogaInputValue("prorrogaDosisMedPrincipal"),
                    medidaMedicamentoPrincipal: getProrrogaInputValue("prorrogaMedidaMedPrincipal"),
                    viaAdministracionMedicamentoPrincipal: getProrrogaInputValue("prorrogaViaMedPrincipal"),
                    frecuenciaAdministracionMxPrincipal: getProrrogaInputValue("prorrogaFrecuenciaMedPrincipal"),
                    diasMedicamentoPrincipal: getProrrogaInputValue("prorrogaDiasMedPrincipal"),
                    tieneSegundoMedicamento: !!(prorrogaMed2Toggle?.checked),
                    nombreMedicamentoNumero2: getProrrogaInputValue("prorrogaNombreMed2"),
                    dosisMedicamento2: getProrrogaInputValue("prorrogaDosisMed2"),
                    medidaMedicamento2: getProrrogaInputValue("prorrogaMedidaMed2"),
                    viaAdministracionMedicamento2: getProrrogaInputValue("prorrogaViaMed2"),
                    frecuenciaAdministracionMedicamento2: getProrrogaInputValue("prorrogaFrecuenciaMed2"),
                    diasMedicamento2: getProrrogaInputValue("prorrogaDiasMed2"),
                    tieneTercerMedicamento: !!(prorrogaMed3Toggle?.checked),
                    nombreMedicamentoNumero3: getProrrogaInputValue("prorrogaNombreMed3"),
                    dosisMedicamento3: getProrrogaInputValue("prorrogaDosisMed3"),
                    medidaMedicamento3: getProrrogaInputValue("prorrogaMedidaMed3"),
                    viaAdministracionMedicamento3: getProrrogaInputValue("prorrogaViaMed3"),
                    frecuenciaAdministracionMedicamento3: getProrrogaInputValue("prorrogaFrecuenciaMed3"),
