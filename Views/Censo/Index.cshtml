            const showFeedbackModal = (title, bodyHtml, tone) => {
                if (!feedbackModalElement || !feedbackModalTitle || !feedbackModalBody || !feedbackModalHeader) {
                    window.alert(`${title}\n${stripHtml(bodyHtml)}`);
                    return;
                }

                feedbackModalTitle.textContent = title;
                feedbackModalBody.innerHTML = bodyHtml;
                feedbackModalHeader.classList.remove("bg-success-subtle", "text-success-emphasis", "bg-danger-subtle", "text-danger-emphasis", "bg-warning-subtle", "text-warning-emphasis");

                if (tone === "success") {
                    feedbackModalHeader.classList.add("bg-success-subtle", "text-success-emphasis");
                } else if (tone === "danger") {
                    feedbackModalHeader.classList.add("bg-danger-subtle", "text-danger-emphasis");
                } else {
                    feedbackModalHeader.classList.add("bg-warning-subtle", "text-warning-emphasis");
                }

                if (window.bootstrap && window.bootstrap.Modal) {
                    window.bootstrap.Modal.getOrCreateInstance(feedbackModalElement).show();
                    return;
                }

                window.alert(`${title}\n${stripHtml(bodyHtml)}`);
            };

            const buildListHtml = (items) => {
