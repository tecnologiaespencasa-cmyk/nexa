                        dailyDoses: getFormValue("NumeroDosisMedicamento4"),
                        days: getFormValue("DiasMedicamento4"),
                        startDate: fechaInicio,
                        endDate: fechaFin
                    },
                    {
                        name: getFormValue("NombreMedicamentoNumero5"),
                        dose: getFormValue("DosisMedicamento5"),
                        frequency: getFormValue("FrecuenciaAdministracionMedicamento5"),
                        dailyDoses: getFormValue("NumeroDosisMedicamento5"),
                        days: getFormValue("DiasMedicamento5"),
                        startDate: fechaInicio,
                        endDate: fechaFin
                    },
                    {
                        name: getFormValue("NombreMedicamentoNumero6"),
                        dose: getFormValue("DosisMedicamento6"),
                        frequency: getFormValue("FrecuenciaAdministracionMedicamento6"),
                        dailyDoses: getFormValue("NumeroDosisMedicamento6"),
                        days: getFormValue("DiasMedicamento6"),
                        startDate: fechaInicio,
                        endDate: fechaFin
                    }
                ].filter((medication) => hasRequisitionMedication(medication.name));
            };

            const buildRequisitionRows = () => {
                const medications = getRequisitionMedications();
                const rows = medications.map((medication) => ({
                    descripcion: medication.name,
                    detalle: "",
                    cantidad: formatRequisitionQuantity(calculateMedicationRequisitionQuantity(medication)),
                    fechaInicio: medication.startDate,
                    fechaFin: medication.endDate
                }));

                const pushDistinctCatalogRows = (description, field, quantity) => {
                    const details = new Map();
                    medications.forEach((medication) => {
                        const metadata = medicamentoCatalogByName.get(normalizeMedicationKey(medication.name));
                        const detail = catalogValue(metadata, field);
                        if (detail) {
                            details.set(detail.toUpperCase(), detail);
                        }
                    });

                    details.forEach((detail) => {
                        rows.push({
                            descripcion: description,
                            detalle: detail,
                            cantidad: typeof quantity === "function" ? quantity() : quantity,
                            fechaInicio: medications[0]?.startDate || "",
                            fechaFin: medications[0]?.endDate || ""
                        });
                    });
                };

                const aplicacionesTotales = formatRequisitionQuantity(parseRequisitionDecimal(getFormValue("AplicacionesTotales")));
                const diasTratamientoIv = getFormValue("DiasTratamientoIv");
                pushDistinctCatalogRows("SOLUCION PARA DILUCION", "SolucionParaDilucion", "");
                pushDistinctCatalogRows("JERINGA", "Jeringa", aplicacionesTotales);

                [
                    ["JELCO #22", calculateEveryThreeDaysQuantity(diasTratamientoIv, true)],
                    ["ATI", calculateEveryThreeDaysQuantity(diasTratamientoIv)],
                    ["MACROGOTERO", calculateEveryThreeDaysQuantity(diasTratamientoIv)],
                    ["BURETRA", calculateEveryThreeDaysQuantity(diasTratamientoIv)],
                    ["GUANTES (PAR)", parseRequisitionDecimal(getFormValue("AplicacionesTotales"))]
                ].forEach(([descripcion, cantidad]) => {
