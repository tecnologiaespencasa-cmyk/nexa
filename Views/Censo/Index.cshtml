                        <div class="censo-kardex-section-title censo-kardex-section-title--payer">Asegurador</div>
                        <div class="censo-kardex-section-title censo-kardex-section-title--diagnosis">Diagn&oacute;stico descriptivo</div>

                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">Paciente:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="paciente" value="@Model.NombrePaciente" />
                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">Asegurador:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="asegurador" value="SURA" />
                        <textarea class="censo-kardex-patient-table__cell censo-kardex-patient-table__diagnosis" data-kardex-field="diagnostico" aria-label="Diagn&oacute;stico descriptivo">@Model.DiagnosticoDescriptivo</textarea>

                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">Documento de identidad:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="documento" value="@kardexDocumento" />
                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">Peso:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="peso" />

                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">Direccion:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="direccion" value="@Model.Direccion" />
                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">Edad:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="edad" value="@Model.Edad" />

                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">telefonos:</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="telefonos" value="@kardexTelefonos" />
                        <label class="censo-kardex-patient-table__cell censo-kardex-patient-table__label">CIE10</label>
                        <input class="censo-kardex-patient-table__cell" data-kardex-field="cie10" value="@Model.CodigoCie10" />
                    </div>

                    <div class="censo-kardex-section-title censo-kardex-section-title--full">Registro de aplicaci&oacute;n de medicamentos</div>
                    <div class="censo-kardex-med-table" role="table" aria-label="Medicamentos kardex">
                        <div class="censo-kardex-med-table__header" role="row">
                            <span>PRESENTACION<br />MEDICAMENTOS</span>
                            <span>DOSIS Y FRECUENCIA</span>
                            <span>VEHICULO DE RECONSTITUCION</span>
                            <span>VOLUMEN DE DILUCI&Oacute;N</span>
                            <span>TIEMPO DE INFUSI&Oacute;N</span>
                            <span>ES FOTOSENSIBLE</span>
                            <span>CADENA DE FRIO</span>
                            <span>Aislamiento</span>
                            <span>ESTABILIDAD</span>
                            <span>BOMBA DE INFUSI&Oacute;N</span>
                            <span>FECHA INICIO</span>
                            <span>FECHA FIN</span>
                        </div>
                        @for (var kardexRow = 1; kardexRow <= 3; kardexRow++)
                        {
                            <div class="censo-kardex-med-table__row" role="row" data-kardex-med-row="@kardexRow">
                                <textarea aria-label="Presentaci&oacute;n medicamentos @kardexRow" data-kardex-med-field="presentacion">Medicamento @kardexRow</textarea>
                                <textarea aria-label="Dosis y frecuencia @kardexRow" data-kardex-med-field="dosisFrecuencia"></textarea>
                                <textarea aria-label="Veh&iacute;culo de reconstituci&oacute;n @kardexRow" data-kardex-med-field="vehiculoReconstitucion"></textarea>
                                <input aria-label="Volumen de diluci&oacute;n @kardexRow" data-kardex-med-field="volumenDilucion" />
                                <input aria-label="Tiempo de infusi&oacute;n @kardexRow" data-kardex-med-field="tiempoInfusion" />
                                <input aria-label="Es fotosensible @kardexRow" data-kardex-med-field="fotosensible" />
                                <input aria-label="Cadena de frio @kardexRow" data-kardex-med-field="cadenaFrio" />
                                <input aria-label="Aislamiento @kardexRow" data-kardex-med-field="aislamiento" />
                                <input aria-label="Estabilidad @kardexRow" data-kardex-med-field="estabilidad" />
                                <input aria-label="Bomba de infusi&oacute;n @kardexRow" data-kardex-med-field="bombaInfusion" />
                                <input aria-label="Fecha inicio @kardexRow" data-kardex-med-field="fechaInicio" />
                                <input aria-label="Fecha fin @kardexRow" data-kardex-med-field="fechaFin" />
                            </div>
                        }
                    </div>

                    <div class="censo-kardex-footer-table">
                        <label>OBSERVACI&Oacute;N:</label>
                        <textarea data-kardex-field="observaciones">@Model.ObservacionesPlanManejo</textarea>
                        <label>Cambio de equipo:</label>
                        <input data-kardex-field="cambioEquipo" value="CADA 3 DIAS" />
                        <label>MEDICO TRATANTE</label>
                        <input data-kardex-field="medicoTratante" />
                        <label>PROGRAMADOR:</label>
                        <input data-kardex-field="programador" value="@Model.ResponsableLlamadaBienvenida" />
                        <label>AUXILIAR ASIGNADO</label>
                        <input data-kardex-field="auxiliarAsignado" value="@Model.AuxiliarAsignado" />
                    </div>
                </div>
                </section>
                <section class="censo-document-pane" id="censoRequisicionPane" data-censo-document-pane="requisicion" role="tabpanel" aria-labelledby="censoRequisicionTabButton">
                    <div class="censo-requisition-sheet" aria-label="Requisici&oacute;n aplicaci&oacute;n de medicamentos">
                        <div class="censo-requisition-sheet__head">
                            <div class="censo-requisition-sheet__logo">
                                <img src="~/images/logo.png" asp-append-version="true" alt="Especialistas En Casa" />
                            </div>
                            <div class="censo-requisition-sheet__title">REQUISICI&Oacute;N APLICACI&Oacute;N DE MEDICAMENTOS</div>
                            <div class="censo-requisition-sheet__meta">
                                <label>C&oacute;digo:<input data-requisition-field="codigoFormato" value="FO-SEF-07" /></label>
                                <label>Versi&oacute;n:<input data-requisition-field="versionFormato" value="03" /></label>
                                <label>pagina:<input data-requisition-field="paginaFormato" value="1 de 1" /></label>
                                <label>Fecha:<input data-requisition-field="fechaFormato" value="01/05/2026" /></label>
                            </div>
                        </div>

                        <div class="censo-requisition-section-title">RESPONSABLES</div>
                        <div class="censo-requisition-responsibles">
                            <label>AUXILIAR ENCARGADO</label>
                            <input data-requisition-field="auxiliarEncargado" value="@Model.AuxiliarAsignado" />
                            <label>REALIZADO POR</label>
                            <input data-requisition-field="realizadoPor" value="@Model.NombreRealizaKardex" />
                        </div>

                        <div class="censo-requisition-section-title">DATOS DEL PACIENTE</div>
                        <div class="censo-requisition-patient">
                            <label>Paciente:</label>
                            <input data-requisition-field="paciente" value="@Model.NombrePaciente" />
                            <label>AUTORIZACION</label>
                            <input data-requisition-field="autorizacion" value="@Model.AutorizacionEvento" />

                            <label>Documento identidad:</label>
                            <input data-requisition-field="documento" value="@Model.NumeroIdentificacion" />
                            <label>Fecha de solicitud:</label>
                            <input data-requisition-field="fechaSolicitud" />

                            <label>Direccion:</label>
                            <input data-requisition-field="direccion" value="@Model.Direccion" />
                            <label>telefonos:</label>
                            <input data-requisition-field="telefonos" value="@kardexTelefonos" />

                            <label>Diagnostico</label>
                            <input class="censo-requisition-patient__diagnosis" data-requisition-field="diagnostico" value="@($"{Model.CodigoCie10} {Model.DiagnosticoDescriptivo}".Trim())" />
                        </div>

                        <div class="censo-requisition-section-title censo-requisition-section-title--center">DETALLE DE LA REQUISICI&Oacute;N</div>
                        <div class="censo-requisition-detail" role="table" aria-label="Detalle de la requisici&oacute;n">
                            <div class="censo-requisition-detail__header" role="row">
                                <span>Item</span>
                                <span>DESCRIPCION</span>
                                <span>DETALLE</span>
                                <span>CANTIDAD</span>
                                <span>Fecha de inicio</span>
                                <span>Fecha de finalizaci&oacute;n</span>
                            </div>
                            @for (var requisicionRow = 1; requisicionRow <= 16; requisicionRow++)
                            {
                                <div class="censo-requisition-detail__row" role="row" data-requisition-row="@requisicionRow">
                                    <input aria-label="Item @requisicionRow" data-requisition-item-field="item" value="@requisicionRow" />
                                    <input aria-label="Descripci&oacute;n @requisicionRow" data-requisition-item-field="descripcion" />
                                    <input aria-label="Detalle @requisicionRow" data-requisition-item-field="detalle" />
                                    <input aria-label="Cantidad @requisicionRow" data-requisition-item-field="cantidad" />
                                    <input aria-label="Fecha de inicio @requisicionRow" data-requisition-item-field="fechaInicio" />
                                    <input aria-label="Fecha de finalizaci&oacute;n @requisicionRow" data-requisition-item-field="fechaFin" />
                                </div>
                            }
                        </div>
                    </div>
                </section>
            </div>
            <div class="censo-adjuntos-panel px-3 pb-2 border-top pt-2">
                <div class="d-flex align-items-center gap-2 mb-2">
                    <strong class="small">Adjuntos PDF</strong>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="subirAdjuntoBtn" title="Subir adjunto PDF">
                        <svg viewBox="0 0 24 24" width="16" height="16" focusable="false" aria-hidden="true" style="vertical-align:middle"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
                        Subir PDF
                    </button>
                    <input type="file" id="adjuntoFileInput" accept=".pdf,application/pdf" class="d-none" aria-label="Seleccionar archivo PDF" />
                    <span id="adjuntoUploadStatus" class="small text-muted"></span>
                </div>
                <ul class="list-group list-group-flush censo-adjuntos-list" id="adjuntosList" style="max-height:140px;overflow-y:auto;"></ul>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-outline-success" id="guardarDocumentosBtn">
                    <svg viewBox="0 0 24 24" width="16" height="16" focusable="false" aria-hidden="true" style="vertical-align:middle;margin-right:4px"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
                    <span>Guardar</span>
                </button>
                <button type="button" class="btn btn-primary censo-kardex-send-button" id="enviarFarmaciaKardexBtn">
                    <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                        <path d="M21 3L3 10.2l6.7 2.6 2.7 8.2 3.2-5.1 5.4 4.1L21 3z"></path>
                        <path d="M9.7 12.8L21 3"></path>
                    </svg>
                    <span>Enviar a farmacia</span>
                </button>
            </div>
        </div>
    </div>
</div>

