</div>

@section Scripts
{
    <partial name="_ValidationScriptsPartial" />
    <script>
        (() => {
            const validarDireccionUrl = "@Url.Action("ValidarDireccion", "Censo")";
            const buscarBarriosUrl = "@Url.Action("BuscarBarrios", "Censo")";
            const defaultsMunicipioUrl = "@Url.Action("ObtenerDefaultsMunicipio", "Censo")";
            const buscarDiagnosticoCie10Url = "@Url.Action("BuscarDiagnosticoCie10", "Censo")";
            const guardarProrrogaUrl = "@Url.Action("GuardarProrroga", "Censo")";
            const enviarFarmaciaUrl = "@Url.Action("EnviarAFarmacia", "Censo")";
            const guardarDocumentosUrl = "@Url.Action("GuardarDocumentos", "Censo")";
            const obtenerDocumentosUrl = "@Url.Action("ObtenerDocumentos", "Censo")";
            const indexUrl = "@Url.Action("Index", "Censo")";
            const subirAdjuntoUrl = "@Url.Action("SubirAdjunto", "Censo")";
            const eliminarAdjuntoUrl = "@Url.Action("EliminarAdjunto", "Censo")";
            const descargarAdjuntoUrl = "@Url.Action("DescargarAdjunto", "Censo")";
            const obtenerAdjuntosUrl = "@Url.Action("ObtenerAdjuntos", "Censo")";
            const medicamentoCatalog = @Html.Raw(medicamentoCatalogJson);
            const direccionInput = document.getElementById("direccionInput");
            const validarDireccionBtn = document.getElementById("validarDireccionBtn");
            const limpiarDireccionBtn = document.getElementById("limpiarDireccionBtn");
            const direccionMensaje = document.getElementById("direccionValidacionMensaje");
            const direccionServerMensaje = document.getElementById("direccionValidacionServerMensaje");
            const asumirDireccionCheck = document.getElementById("asumirDireccionErradaCheck");
            const form = document.getElementById("censoForm");
            const editingRecordIdInput = form ? form.querySelector("input[name='EditingRecordId']") : null;
            const enviarFarmaciaKardexBtn = document.getElementById("enviarFarmaciaKardexBtn");
            const cedulaFiltroInput = document.getElementById("cedulaFiltroInput");
            const buscarCedulaBtn = document.getElementById("buscarCedulaBtn");
            const limpiarCedulaBtn = document.getElementById("limpiarCedulaBtn");
