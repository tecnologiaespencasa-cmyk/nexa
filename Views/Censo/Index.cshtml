                    diasMedicamento5: getProrrogaInputValue("prorrogaDiasMed5"),
                    tieneSextoMedicamento: !!(prorrogaMed6Toggle?.checked),
                    nombreMedicamentoNumero6: getProrrogaInputValue("prorrogaNombreMed6"),
                    dosisMedicamento6: getProrrogaInputValue("prorrogaDosisMed6"),
                    medidaMedicamento6: getProrrogaInputValue("prorrogaMedidaMed6"),
                    viaAdministracionMedicamento6: getProrrogaInputValue("prorrogaViaMed6"),
                    frecuenciaAdministracionMedicamento6: getProrrogaInputValue("prorrogaFrecuenciaMed6"),
                    diasMedicamento6: getProrrogaInputValue("prorrogaDiasMed6"),
                    aplicacionesTotales: getProrrogaInputValue("prorrogaAplicacionesTotales"),
                    diasTratamientoIv: getProrrogaInputValue("prorrogaDiasTratamientoIv"),
                    fechaInicioTratamiento: getProrrogaInputValue("prorrogaFechaInicio"),
                    fechaFinTratamiento: getProrrogaInputValue("prorrogaFechaFin"),
                    fechaPromesaInicioTto: getProrrogaInputValue("prorrogaFechaPromesa"),
                    horaPromesaDesde: getProrrogaInputValue("prorrogaHoraDesde"),
                    horaPromesaHasta: getProrrogaInputValue("prorrogaHoraHasta"),
                    auxiliarAsignado: getProrrogaInputValue("prorrogaAuxiliarAsignado"),
                    numeroDiasExtension: getProrrogaInputValue("prorrogaNumeroDiasExtension"),
                    notificadoAsegurador: !!(document.getElementById("prorrogaNotificadoAsegurador")?.checked),
                });

                const loadProrrogaPayload = (data) => {
                    if (!data) return;
                    const set = (id, val) => { const el = document.getElementById(id); if (el) el.value = val || ""; };
                    const setToggle = (toggle, container, flag) => {
                        if (toggle) {
                            toggle.checked = !!flag;
                            container?.classList.toggle("d-none", !flag);
                        }
                    };
                    set("prorrogaNombreMedPrincipal", data.nombreMedicamentoPrincipal);
                    set("prorrogaDosisMedPrincipal", data.dosisMedicamentoPrincipal);
                    set("prorrogaMedidaMedPrincipal", data.medidaMedicamentoPrincipal);
                    set("prorrogaViaMedPrincipal", data.viaAdministracionMedicamentoPrincipal);
                    set("prorrogaFrecuenciaMedPrincipal", data.frecuenciaAdministracionMxPrincipal);
                    set("prorrogaDiasMedPrincipal", data.diasMedicamentoPrincipal);
                    setToggle(prorrogaMed2Toggle, prorrogaMed2Container, data.tieneSegundoMedicamento);
