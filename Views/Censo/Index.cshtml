            const syncSelectPlaceholderState = (select) => {
                if (!select) {
                    return;
                }

                const hasValue = String(select.value || "").trim().length > 0;
                select.classList.toggle("is-placeholder", !hasValue);
            };

            const ensureHiddenPlaceholderOption = (select, placeholderText = "Selecciona...") => {
                if (!select) {
                    return;
                }

                let firstOption = select.options.length > 0 ? select.options[0] : null;
                const firstValue = firstOption ? String(firstOption.value || "").trim() : "";
                const firstText = firstOption ? String(firstOption.textContent || "").trim() : "";
                const firstLooksLikePlaceholder = firstOption
                    && firstValue === ""
                    && firstText.toLowerCase().startsWith("selecciona");

                if (!firstLooksLikePlaceholder && !Array.from(select.options).some((option) => String(option.value || "").trim() === "")) {
                    const placeholderOption = document.createElement("option");
                    placeholderOption.value = "";
                    placeholderOption.textContent = placeholderText;
                    select.insertBefore(placeholderOption, select.firstChild);
                    firstOption = placeholderOption;
                }

                if (firstOption && String(firstOption.value || "").trim() === "") {
                    firstOption.disabled = true;
                    firstOption.hidden = true;
                    if (!String(select.value || "").trim()) {
                        select.value = "";
                        firstOption.selected = true;
                    }
                }

                syncSelectPlaceholderState(select);
            };

            const initializeCensoSelectPlaceholders = () => {
                censoSelects.forEach((select) => {
