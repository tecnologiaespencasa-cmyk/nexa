@model UserPermissionAssignmentViewModel
@{
    ViewData["Title"] = "Permisos por pantalla";
}

<h1 class="h3 mb-2">Permisos por pantalla</h1>
<p class="text-muted">Usuario: <strong>@Model.Username</strong> - @Model.FullName</p>

<form asp-action="Permissions" method="post" id="permissionForm">
    <input asp-for="UserId" type="hidden" />
    <input asp-for="Username" type="hidden" />
    <input asp-for="FullName" type="hidden" />
    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

    <div class="row g-3 align-items-center">
        <div class="col-md-5">
            <label class="form-label">Pantallas disponibles</label>
            <select id="availablePermissions" class="form-select" size="10" multiple>
                @foreach (var permission in Model.AvailablePermissions)
                {
                    <option value="@permission.Id" data-code="@permission.Code">@permission.Description</option>
                }
            </select>
        </div>

        <div class="col-md-2 d-grid gap-2">
            <button type="button" class="btn btn-outline-primary" id="moveRight">&gt;</button>
            <button type="button" class="btn btn-outline-primary" id="moveLeft">&lt;</button>
            <button type="button" class="btn btn-outline-secondary" id="moveAllRight">&gt;&gt;</button>
            <button type="button" class="btn btn-outline-secondary" id="moveAllLeft">&lt;&lt;</button>
        </div>

        <div class="col-md-5">
            <label class="form-label">Permisos concedidos</label>
            <select id="grantedPermissions" name="GrantedPermissionIds" class="form-select" size="10" multiple>
                @foreach (var permission in Model.GrantedPermissions)
                {
                    <option value="@permission.Id" data-code="@permission.Code">@permission.Description</option>
                }
            </select>
        </div>
    </div>

    <div class="mt-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Guardar permisos</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Volver</a>
    </div>
</form>

@section Scripts
{
    <script>
        (function() {
            const available = document.getElementById("availablePermissions");
            const granted = document.getElementById("grantedPermissions");
            const form = document.getElementById("permissionForm");

            function moveSelected(from, to) {
                const selected = Array.from(from.selectedOptions);
                selected.forEach(option => to.appendChild(option));
                sortOptions(from);
                sortOptions(to);
            }

            function moveAll(from, to) {
                Array.from(from.options).forEach(option => to.appendChild(option));
                sortOptions(from);
                sortOptions(to);
            }

            function sortOptions(select) {
                const sorted = Array.from(select.options)
                    .sort((a, b) => a.text.localeCompare(b.text));

                sorted.forEach(option => select.appendChild(option));
            }

            document.getElementById("moveRight").addEventListener("click", function() {
                moveSelected(available, granted);
            });

            document.getElementById("moveLeft").addEventListener("click", function() {
                moveSelected(granted, available);
            });

            document.getElementById("moveAllRight").addEventListener("click", function() {
                moveAll(available, granted);
            });

            document.getElementById("moveAllLeft").addEventListener("click", function() {
                moveAll(granted, available);
            });

            form.addEventListener("submit", function() {
                Array.from(granted.options).forEach(option => option.selected = true);
            });
        })();
    </script>
}
